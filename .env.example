# N3 Global Tech — environment variables
#
# Copy this file to `.env` for local dev.
# On Vercel, set these in: Project → Settings → Environment Variables.
#
# These vars are SERVER-SIDE only (no PUBLIC_ prefix). They live on the
# Vercel serverless function that handles /api/contact and never get
# inlined into client-side JavaScript or exposed in the browser.

# CRM webhook endpoint that receives leads from the contact form.
# Example: https://crm.yourdomain.com/api/webhook/enquiry
CRM_API_URL=

# Bearer token your CRM expects in the Authorization header.
CRM_API_TOKEN=
