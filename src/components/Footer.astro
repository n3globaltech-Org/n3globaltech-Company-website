---
const year = new Date().getFullYear();

const footerLinks = {
  Company: [
    { href: "/", label: "Home" },
    { href: "/about/", label: "About Us" },
    { href: "/our-mission/", label: "Our Mission" },
    { href: "/services/", label: "Services" },
    { href: "/products/", label: "Our Products" },
    { href: "/work/", label: "Our Work" },
    { href: "/contact/", label: "Contact Us" },
  ],
  Services: [
    { href: "/custom-software-development/", label: "Custom Software Development" },
    { href: "/saas-development-company/", label: "SaaS Development" },
    { href: "/services#web", label: "Web Development" },
    { href: "/services#mobile", label: "Mobile Apps" },
    { href: "/services#ai", label: "AI & Automation" },
  ],
  Resources: [
    { href: "/blog/", label: "Blog" },
    { href: "/guides/", label: "Engineering Guides" },
    { href: "/work/", label: "Case Studies" },
    { href: "/products/", label: "Our SaaS Products" },
    { href: "/contact/", label: "Get a Quote" },
  ],
  Connect: [
    { href: "mailto:contact@n3global.tech", label: "contact@n3global.tech" },
    { href: "tel:+919645091256", label: "+91 96450 91256" },
    { href: "https://www.linkedin.com/company/n3-global-tech", label: "LinkedIn" },
    // { href: "#", label: "Twitter / X" }, // hidden until profile URL is ready
    { href: "https://www.instagram.com/n3globaltech?igsh=MWoyYnFuZ3I2cTZxcQ%3D%3D&utm_source=qr", label: "Instagram" },
  ],
};
---

<footer class="footer">
  <div class="footer__glow"></div>
  <div class="container">
    <div class="footer__top">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="/n3logo.webp" alt="N3 Global Tech" class="footer-logo-img" width="38" height="38" />
          <span>N3 Global Tech</span>
        </a>
        <p class="footer__tagline">
          Empowering businesses through innovative technology solutions that drive growth, efficiency and transformation. Operating as N3 Global Tech (n3global.tech / N3GlobalTech / n3globaltech).
        </p>
        <address class="footer__nap">
          <strong>N3 Global Tech</strong><br />
          TK Junction, Near Capital Mall,<br />
          Thana, Kannur, Kerala 670002, India
        </address>

      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([group, links]) => (
        <div class={`footer__col footer__col--${group.toLowerCase()}`}>
          <h4 class="footer__col-title">{group}</h4>
          <ul class="footer__col-links">
            {links.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} N3 Global Tech. All rights reserved.</p>
      <div class="footer__bottom-links">
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/terms-of-service/">Terms of Service</a>
        <a href="/cookie-policy/">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--gray-900);
    color: var(--gray-400);
    padding-top: 5rem;
    position: relative;
    overflow: hidden;
  }

  .footer__glow {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(14,165,233,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1.2fr 1.2fr 1fr 1.4fr;
    gap: 2.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  /* Brand */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--white);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.15rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .footer-logo-img {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    object-fit: contain;
  }

  .footer__tagline {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--gray-400);
    margin-bottom: 1.5rem;
    max-width: 320px;
  }

  .footer__nap {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--gray-400);
    font-style: normal;
    margin-bottom: 1.75rem;
    max-width: 320px;
  }
  .footer__nap strong {
    color: var(--white);
    font-weight: 700;
  }
  .footer__nap a {
    color: var(--gray-400);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer__nap a:hover {
    color: var(--sky-300);
  }

  /* Columns */
  .footer__col-title {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--white);
    margin-bottom: 1.25rem;
  }

  .footer__col-links {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer__col-links a {
    font-size: 0.88rem;
    color: var(--gray-400);
    transition: var(--transition);
    display: block;
  }

  .footer__col-links a:hover {
    color: var(--sky-400);
    transform: translateX(3px);
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.75rem 0;
    font-size: 0.82rem;
    color: var(--gray-500);
  }

  .footer__bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer__bottom-links a {
    color: var(--gray-500);
    transition: color 0.2s;
  }

  .footer__bottom-links a:hover {
    color: var(--sky-400);
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer__bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    .footer__bottom-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
    :global(.footer__col--company) {
      display: none !important;
    }
  }

  /* Removed 400px breakpoint keeping 2-column layout on all small devices */
</style>
