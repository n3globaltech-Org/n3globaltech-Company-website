---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    category: "E-Commerce",
    name: "enJoyful Life",
    desc: "A high-performance e-commerce platform for a natural skincare brand. It features seamless product discovery, secure payments, and a responsive UI optimized for scalability.",
    technologies: "Next.js, Tailwind, Appwrite, AWS",
    client: "enJoyful Life",
    status: "Development Ongoing",
    link: "https://enjoyful.vercel.app/",
    image: "/products/ecom.webp",
  },
  {
    category: "EdTech & Talent Tech",
    name: "ShareInfo",
    desc: "ShareInfo is a multi-sided AI-powered talent ecosystem designed to bridge the gap between students, educational institutions, and recruiters. The platform integrates learning, mentorship, and hiring into a unified system, enabling efficient skill development and smarter recruitment through data-driven matching.",
    technologies: "AI, Modern Web Stack",
    client: "ShareInfo",
    link: "https://share-info-product-website.vercel.app/",
    image: "/products/shareinfo.webp",
  },
  {
    category: "Digital Transformation & CRM",
    name: "Viera Natural Wooden Flooring",
    desc: "A digital transformation featuring an immersive 3D website and custom CRM. It elegantly showcases the brand's portfolio while the CRM manages staff operations, site progress, and task automation.",
    technologies: "3D Animations, React, Node.js",
    client: "Viera Natural Wooden Flooring",
    link: "https://viera-two.vercel.app/",
    image: "/products/viera.webp",
    caseStudy: {
      challenge: "Viera's premium wooden-flooring brand was being represented by a static brochure site that did the product no favours. Behind the scenes, site supervisors and office staff coordinated installations through WhatsApp groups and spreadsheets that nobody fully trusted.",
      build: "We shipped two pieces in parallel. The public site is an immersive 3D experience that lets prospects rotate, view, and interact with flooring patterns in a real-room context, replacing flat photos with something that actually conveys texture and finish. The internal CRM gives the operations team a single dashboard for sites, staff, tasks, and progress photos, with role-based access for owners, supervisors, and on-site teams.",
      outcome: "Sales conversations now start with the product feeling premium before the first phone call. Site visibility is real-time instead of end-of-week.",
      stack: ["React", "Three.js", "Node.js", "PostgreSQL"],
    },
  },
  {
    category: "Aviation Services",
    name: "Flyger Aviation Services",
    desc: "A professional corporate website for a global aviation support provider specializing in end-to-end flight operations. The site showcases their flight planning, permit acquisition, dispatch coordination, and crew logistics services with a clean, premium UI tailored for international operators.",
    technologies: "Modern Web Stack",
    client: "Flyger Aviation Services",
    link: "https://flyger.aero",
    image: "/products/flyger.webp",
    caseStudy: {
      challenge: "Flyger needed a corporate web presence that matched the seriousness of their actual operation: end-to-end flight support for international operators. The previous site looked like a generic agency template, which created friction during enterprise sales conversations.",
      build: "We rebuilt the site from scratch with a clean, premium UI that walks prospects through their service map (flight planning, permits, dispatch, crew logistics) without overwhelming them. The information architecture was rebuilt around how aviation buyers actually evaluate providers, and the responsive layout works equally well on a phone in a hangar and a desktop in a procurement office.",
      outcome: "Live at flyger.aero. Inquiry-to-conversation time has dropped because the site does more of the qualifying upfront.",
      stack: ["Next.js", "TypeScript", "Tailwind CSS", "Vercel"],
    },
  },

  {
    category: "Corporate Website",
    name: "Happiness Address",
    desc: "A dynamic corporate website for a creative marketing and branding agency. It highlights print media services, corporate branding, and promotional solutions through a clean, engaging UI designed to attract and convert clients.",
    technologies: "Modern Web Stack",
    client: "Happiness Address",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/hapadrs.pdf",
    image: "/products/happiness-address.webp",
  },

  {
    category: "Social Impact Platform",
    name: "Impulse Loop",
    desc: "A modern, flexible volunteering ecosystem that connects charities, businesses, and volunteers. It revolutionizes traditional volunteering by rewarding contributions with Impact Coins, creating a self-sustaining platform for giving back.",
    technologies: "Modern Web Stack",
    client: "Impulse Loop",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/impulseloop.pdf",
    image: "/products/impulseloop.webp",
  },
  {
    category: "Custom Printing Services",
    name: "Rida",
    desc: "A dedicated platform for high-quality custom printing solutions. From precise tags to durable labels and bulk business orders, Rida delivers tailored perfection, fast turnaround, and seamless online ordering.",
    technologies: "Modern Web Stack",
    client: "Rida",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/Rida.pdf",
    image: "/products/Rida.webp",
  },
  {
    category: "Training & Certification",
    name: "Vertigoo",
    desc: "A premier IRATA and work-at-height training program provider in GCC & India. Vertigoo features accredited courses, professional job placements, and a state-of-the-art training center.",
    technologies: "EdTech, Modern Web Stack",
    client: "Vertigoo",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/VERTIGOO.pdf",
    image: "/products/Vertigoo.webp",
  },
  {
    category: "Immigration Consulting",
    name: "Ask Kubeir",
    desc: "A comprehensive Canadian immigration platform offering expert guidance and seamless processing. Ask Kubeir supports aspirants seeking temporary or permanent residency, Express Entry, and connects Canadian employers with global talent.",
    technologies: "Modern Web Stack",
    client: "Ask Kubeir",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/WhiteHorseLandingPage.pdf",
    image: "/products/whitehorse.webp",
  },
];
---

<Layout
  title="Portfolio & Case Studies"
  description="Real client success stories: e-commerce, AI talent ecosystems, 3D websites, custom CRMs, aviation portals and digital transformations built end-to-end."
  keywords="software development portfolio, web development case studies, custom CRM examples, e-commerce development portfolio, 3D website portfolio, digital transformation case studies, aviation website, AI talent platform"
>
  <div class="page-wrapper">
    <Navbar />

    <section class="solutions-showcase">
      <div class="container">
        
        <div class="showcase-header">
          <h1 class="showcase-title">Client Success Stories</h1>
          <p class="showcase-subtitle">
            A selection of <a href="/custom-software-development/">custom software</a> and <a href="/saas-development-company/">SaaS platforms</a> we've shipped, from immersive 3D corporate sites to multi-tenant CRMs and aviation portals. Every project below is live, every client is real.
          </p>
        </div>

        <div class="showcase-list">
          {projects.map((project, index) => {
            return (
              <div class={`showcase-item ${index % 2 !== 0 ? 'reverse' : ''}`}>
                <div class="item-visual">
                  <div class="img-wrapper">
                    <img src={project.image} alt={project.name} loading="lazy" />
                    <div class="img-overlay"></div>
                  </div>
                </div>
                
                <div class="item-content">
                  <div class="tag">{project.category}</div>
                  <h2 class="name">{project.name}</h2>
                  <p class="desc">{project.desc}</p>

                  {project.caseStudy && (
                    <div class="case-study">
                      <div class="case-study__block">
                        <h3 class="case-study__label">Challenge</h3>
                        <p>{project.caseStudy.challenge}</p>
                      </div>
                      <div class="case-study__block">
                        <h3 class="case-study__label">What we built</h3>
                        <p>{project.caseStudy.build}</p>
                      </div>
                      <div class="case-study__block">
                        <h3 class="case-study__label">Outcome</h3>
                        <p>{project.caseStudy.outcome}</p>
                      </div>
                      <div class="case-study__stack">
                        {project.caseStudy.stack.map(s => <span class="case-study__chip">{s}</span>)}
                      </div>
                    </div>
                  )}

                  <div class="tech-client">
                    {!project.caseStudy && <p><strong>Technologies:</strong> {project.technologies}</p>}
                    <p><strong>Client:</strong> {project.client}</p>
                    {project.status && <p><strong>Status:</strong> {project.status}</p>}
                  </div>
                  
                  {(project.pdfLink || project.link) && (
                    <div class="btn-group" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                      {project.pdfLink && (
                        <a href={project.pdfLink} target="_blank" rel="noopener noreferrer" class="btn-case-study">
                          View UI Design
                          <span class="icon-wrap">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
                          </span>
                        </a>
                      )}

                      {project.link && (
                        <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn-live-link">
                          Live Preview
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5L21 3m0 0h-5.25m5.25 0v5.25m-9 13.5H3.75A2.25 2.25 0 011.5 19.5V8.25a2.25 2.25 0 012.25-2.25h5.25" /></svg>
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>

        <div class="coming-soon-projects">
          <h3>More Case Studies Coming Soon ✨</h3>
          <p>We are continuously working with our clients to deliver cutting-edge solutions. Stay tuned as we update our portfolio with more recent successes.</p>
        </div>

      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bottom-cta">
      <div class="container">
        <h2>Ready to build something amazing?</h2>
        <p>Your business could be our next big success story. Let's discuss your requirements and see how we can help.</p>
        <a href="/contact" class="btn btn-primary btn-xl">Get Started</a>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

</Layout>

<style>
  /* Light theme container */
  .page-wrapper {
    background-color: #ffffff !important;
    color: #0f172a !important;
    min-height: 100vh;
  }

  .solutions-showcase {
    padding: calc(60px + 3rem) 0 6rem;
    font-family: var(--font-body);
  }

  .showcase-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .showcase-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #0f172a !important;
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
  }

  .showcase-subtitle {
    max-width: 680px;
    margin: 0 auto;
    color: #475569;
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .showcase-subtitle a {
    color: #0369a1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Showcase List */
  .showcase-list {
    display: flex;
    flex-direction: column;
    gap: 8rem;
  }

  .showcase-item {
    display: flex;
    align-items: center;
    gap: 5rem;
  }

  .showcase-item.reverse {
    flex-direction: row-reverse;
  }

  /* Image block */
  .item-visual {
    flex: 1;
    border-radius: 0.75rem;
    overflow: hidden;
    position: relative;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08); /* Lighter shadow */
    background: #f8fafc;
  }

  .img-wrapper {
    position: relative;
    width: 100%;
    padding-top: 75%; /* 4:3 aspect ratio */
  }

  .img-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.15), transparent);
    pointer-events: none;
  }

  /* Content block */
  .item-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .tag {
    font-size: 0.85rem;
    font-weight: 700;
    color: #64748b;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .name {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: #0f172a !important; /* Dark text */
    margin-bottom: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .desc {
    font-size: 1.05rem;
    color: #475569 !important;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 500px;
  }

  /* Detailed case study */
  .case-study {
    margin: 1.5rem 0 2rem;
    padding: 1.5rem 1.75rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    max-width: 540px;
  }
  .case-study__block { margin-bottom: 1rem; }
  .case-study__block:last-of-type { margin-bottom: 1.25rem; }
  .case-study__label {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sky-700);
    margin: 0 0 0.4rem;
  }
  .case-study__block p {
    font-size: 0.92rem;
    color: #475569;
    line-height: 1.7;
    margin: 0;
  }
  .case-study__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.85rem;
    border-top: 1px solid #e2e8f0;
  }
  .case-study__chip {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #0f172a;
  }

  /* Tech & Client */
  .tech-client {
    font-size: 0.9rem;
    color: #475569;
    margin-bottom: 2.5rem;
  }

  .tech-client p {
    margin-bottom: 0.4rem;
  }

  .tech-client strong {
    color: #0f172a;
    font-weight: 700;
  }

  /* View Case Study Button */
  .btn-case-study {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: var(--primary); /* Use primary sky blue */
    color: #ffffff;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.5rem 0.5rem 0.5rem 1.75rem;
    border-radius: 99px;
    transition: all 0.3s ease;
  }

  .btn-case-study:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(14, 165, 233, 0.25); /* Primary glow */
  }

  .icon-wrap {
    width: 38px;
    height: 38px;
    background: rgba(255, 255, 255, 0.2); /* Semi transparent white */
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }

  .btn-live-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.5rem 1.25rem;
    border-radius: 99px;
    border: 2px solid var(--primary);
    transition: all 0.3s ease;
  }

  .btn-live-link:hover {
    background: var(--primary);
    color: #ffffff;
    box-shadow: 0 10px 25px rgba(14, 165, 233, 0.25);
  }

  /* Coming Soon Section */
  .coming-soon-projects {
    text-align: center;
    padding: 4rem 2rem;
    margin-top: 6rem;
    background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    border-radius: 1.5rem;
    border: 1px dashed #cbd5e1;
  }

  .coming-soon-projects h3 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .coming-soon-projects p {
    color: #64748b;
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Bottom CTA */
  .bottom-cta {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid #f1f5f9;
    background: #fafafa;
  }

  .bottom-cta h2 {
    color: #0f172a;
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .bottom-cta p {
    color: #64748b;
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .showcase-item, .showcase-item.reverse {
      flex-direction: column;
      gap: 3rem;
    }
    .item-visual {
      width: 100%;
    }
    .item-content {
      width: 100%;
      align-items: flex-start;
    }
    .desc, .review-box {
      max-width: 100%;
    }
    .showcase-list {
      gap: 5rem;
    }
  }

  @media (max-width: 768px) {
    .solutions-showcase {
      padding: calc(60px + 1.5rem) 0 4rem;
    }
    .showcase-title {
      font-size: 2.5rem;
      margin-bottom: 2rem;
    }
    .showcase-list {
      gap: 4rem;
    }
    .name {
      font-size: 1.8rem;
    }
    .btn-case-study {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
