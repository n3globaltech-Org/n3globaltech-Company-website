---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    category: "Digital Transformation & CRM",
    name: "Viera Natural Wooden Flooring",
    desc: "A digital transformation featuring an immersive 3D website and custom CRM. It elegantly showcases the brand's portfolio while the CRM manages staff operations, site progress, and task automation.",
    technologies: "3D Animations, React, Node.js",
    client: "Viera Natural Wooden Flooring",
    image: "https://images.unsplash.com/photo-1541123437800-14a33fb6edad?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80",
  },
  {
    category: "Corporate Website",
    name: "anabb.tech",
    desc: "We crafted a professional and scalable website for anabb.tech, focusing on clean UI/UX, performance, and a strong digital identity.",
    technologies: "Modern Web Stack",
    client: "anabb.tech",
    status: "Live",
    link: "https://anabb.tech/",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80",
  },
  {
    category: "E-Commerce",
    name: "enJoyful Life",
    desc: "A high-performance e-commerce platform for a natural skincare brand. It features seamless product discovery, secure payments, and a responsive UI optimized for scalability.",
    technologies: "Next.js, Tailwind, Appwrite, AWS",
    client: "enJoyful Life",
    status: "Development Ongoing",
    link: "https://enjoyful.vercel.app/",
    image: "https://images.unsplash.com/photo-1556228578-0d85b1a4d571?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80",
  },
  {
    category: "Fintech",
    name: "PulseBank Dashboard",
    desc: "A real-time financial analytics dashboard for digital banking, featuring live transaction monitoring and AI-powered spending insights.",
    technologies: "React, Node.js, PostgreSQL, AI/ML",
    client: "PulseBank",
    review: "N3 Global Tech transformed our data infrastructure. The dashboard they built handles 10x more throughput than our old system.",
    image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80",
  },
  {
    category: "Healthcare",
    name: "MediFlow EHR System",
    desc: "A HIPAA-compliant medical records platform for clinics. Includes patient portals, appointment scheduling, and telemedicine integration.",
    technologies: "Next.js, AWS, HIPAA, Telemedicine",
    client: "MediFlow Health",
    review: "Honestly the best tech partner we've worked with. They understood healthcare compliance requirements from day one.",
    image: "https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80",
  },
  {
    category: "E-Commerce",
    name: "RetailNexus Platform",
    desc: "A scalable multi-vendor marketplace platform featuring dynamic pricing, seller analytics, and smart product recommendations.",
    technologies: "Vue.js, Django, Redis, Stripe",
    client: "RetailNexus",
    review: "We went from MVP to $2M monthly GMV in under a year. N3's scalable architecture made that growth possible.",
    image: "https://images.unsplash.com/photo-1472851294502-8ce3b4845a47?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80",
  },
];
---

<Layout title="Our Work | Portfolio" description="Explore N3 Global Tech's portfolio of custom software solutions, digital transformations, and client success stories.">
  <div class="page-wrapper">
    <Navbar />

    <section class="solutions-showcase">
      <div class="container">
        
        <div class="showcase-header">
          <h1 class="showcase-title">Client Success Stories,</h1>
        </div>

        <div class="showcase-list">
          {projects.map((project, index) => {
            return (
              <div class={`showcase-item ${index % 2 !== 0 ? 'reverse' : ''}`}>
                <div class="item-visual">
                  <div class="img-wrapper">
                    <img src={project.image} alt={project.name} loading="lazy" />
                    <div class="img-overlay"></div>
                  </div>
                </div>
                
                <div class="item-content">
                  <div class="tag">{project.category}</div>
                  <h2 class="name">{project.name}</h2>
                  <p class="desc">{project.desc}</p>
                  
                  <div class="tech-client">
                    <p><strong>Technologies:</strong> {project.technologies}</p>
                    <p><strong>Client:</strong> {project.client}</p>
                    {project.status && <p><strong>Status:</strong> {project.status}</p>}
                  </div>
                  
                  <div class="btn-group" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                    <a href="/contact" class="btn-case-study">
                      Start a Project
                      <span class="icon-wrap">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
                      </span>
                    </a>

                    {project.link && (
                      <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn-live-link">
                        Live Preview
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5L21 3m0 0h-5.25m5.25 0v5.25m-9 13.5H3.75A2.25 2.25 0 011.5 19.5V8.25a2.25 2.25 0 012.25-2.25h5.25" /></svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bottom-cta">
      <div class="container">
        <h2>Ready to build something amazing?</h2>
        <p>Your business could be our next big success story. Let's discuss your requirements and see how we can help.</p>
        <a href="/contact" class="btn btn-primary btn-xl">Get Started</a>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

</Layout>

<style>
  /* Light theme container */
  .page-wrapper {
    background-color: #ffffff !important;
    color: #0f172a !important;
    min-height: 100vh;
  }

  .solutions-showcase {
    padding: calc(60px + 3rem) 0 6rem;
    font-family: var(--font-body);
  }

  .showcase-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .showcase-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #0f172a !important; /* Dark gray / black */
    margin-bottom: 0;
    letter-spacing: -0.04em;
  }

  /* Showcase List */
  .showcase-list {
    display: flex;
    flex-direction: column;
    gap: 8rem;
  }

  .showcase-item {
    display: flex;
    align-items: center;
    gap: 5rem;
  }

  .showcase-item.reverse {
    flex-direction: row-reverse;
  }

  /* Image block */
  .item-visual {
    flex: 1;
    border-radius: 1.5rem;
    overflow: hidden;
    position: relative;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08); /* Lighter shadow */
    background: #f8fafc;
  }

  .img-wrapper {
    position: relative;
    width: 100%;
    padding-top: 75%; /* 4:3 aspect ratio */
  }

  .img-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .showcase-item:hover .img-wrapper img {
    transform: scale(1.05);
  }

  .img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.15), transparent);
    pointer-events: none;
  }

  /* Content block */
  .item-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .tag {
    font-size: 0.85rem;
    font-weight: 700;
    color: #64748b;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .name {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: #0f172a !important; /* Dark text */
    margin-bottom: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .desc {
    font-size: 1.05rem;
    color: #475569 !important;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 500px;
  }

  /* Tech & Client */
  .tech-client {
    font-size: 0.9rem;
    color: #475569;
    margin-bottom: 2.5rem;
  }

  .tech-client p {
    margin-bottom: 0.4rem;
  }

  .tech-client strong {
    color: #0f172a;
    font-weight: 700;
  }

  /* View Case Study Button */
  .btn-case-study {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: var(--primary); /* Use primary sky blue */
    color: #ffffff;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.5rem 0.5rem 0.5rem 1.75rem;
    border-radius: 99px;
    transition: all 0.3s ease;
  }

  .btn-case-study:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(14, 165, 233, 0.25); /* Primary glow */
  }

  .icon-wrap {
    width: 38px;
    height: 38px;
    background: rgba(255, 255, 255, 0.2); /* Semi transparent white */
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }

  .btn-live-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.5rem 1.25rem;
    border-radius: 99px;
    border: 2px solid var(--primary);
    transition: all 0.3s ease;
  }

  .btn-live-link:hover {
    background: var(--primary);
    color: #ffffff;
    box-shadow: 0 10px 25px rgba(14, 165, 233, 0.25);
  }

  /* Bottom CTA */
  .bottom-cta {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid #f1f5f9;
    background: #fafafa;
  }

  .bottom-cta h2 {
    color: #0f172a;
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .bottom-cta p {
    color: #64748b;
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .showcase-item, .showcase-item.reverse {
      flex-direction: column;
      gap: 3rem;
    }
    .item-visual {
      width: 100%;
    }
    .item-content {
      width: 100%;
      align-items: flex-start;
    }
    .desc, .review-box {
      max-width: 100%;
    }
    .showcase-list {
      gap: 5rem;
    }
  }

  @media (max-width: 768px) {
    .solutions-showcase {
      padding: calc(60px + 1.5rem) 0 4rem;
    }
    .showcase-title {
      font-size: 2.5rem;
      margin-bottom: 2rem;
    }
    .showcase-list {
      gap: 4rem;
    }
    .name {
      font-size: 1.8rem;
    }
    .btn-case-study {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
