---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    category: "E-Commerce",
    name: "enJoyful Life",
    desc: "A high-performance e-commerce platform for a natural skincare brand. It features seamless product discovery, secure payments, and a responsive UI optimized for scalability.",
    technologies: "Next.js, Tailwind, Appwrite, AWS",
    client: "enJoyful Life",
    status: "Development Ongoing",
    link: "https://enjoyful.vercel.app/",
    image: "/products/ecom.webp",
  },
  {
    category: "EdTech & Talent Tech",
    name: "ShareInfo",
    desc: "ShareInfo is a multi-sided AI-powered talent ecosystem designed to bridge the gap between students, educational institutions, and recruiters. The platform integrates learning, mentorship, and hiring into a unified system, enabling efficient skill development and smarter recruitment through data-driven matching.",
    technologies: "AI, Modern Web Stack",
    client: "ShareInfo",
    link: "https://share-info-product-website.vercel.app/",
    image: "/products/shareinfo.webp",
  },
  {
    category: "Digital Transformation & CRM",
    name: "Viera Natural Wooden Flooring",
    desc: "A digital transformation featuring an immersive 3D website and custom CRM. It elegantly showcases the brand's portfolio while the CRM manages staff operations, site progress, and task automation.",
    technologies: "3D Animations, React, Node.js",
    client: "Viera Natural Wooden Flooring",
    link: "https://viera-two.vercel.app/",
    image: "/products/viera.webp",
  },
  {
    category: "Aviation Services",
    name: "Flyger Aviation Services",
    desc: "A professional corporate website for a global aviation support provider specializing in end-to-end flight operations. The site showcases their flight planning, permit acquisition, dispatch coordination, and crew logistics services with a clean, premium UI tailored for international operators.",
    technologies: "Modern Web Stack",
    client: "Flyger Aviation Services",
    link: "https://flyger.aero",
    image: "/products/flyger.webp",
  },

  {
    category: "Corporate Website",
    name: "Happiness Address",
    desc: "A dynamic corporate website for a creative marketing and branding agency. It highlights print media services, corporate branding, and promotional solutions through a clean, engaging UI designed to attract and convert clients.",
    technologies: "Modern Web Stack",
    client: "Happiness Address",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/hapadrs.pdf",
    image: "/products/happiness-address.webp",
  },

  {
    category: "Social Impact Platform",
    name: "Impulse Loop",
    desc: "A modern, flexible volunteering ecosystem that connects charities, businesses, and volunteers. It revolutionizes traditional volunteering by rewarding contributions with Impact Coins, creating a self-sustaining platform for giving back.",
    technologies: "Modern Web Stack",
    client: "Impulse Loop",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/impulseloop.pdf",
    image: "/products/impulseloop.webp",
  },
  {
    category: "Custom Printing Services",
    name: "Rida",
    desc: "A dedicated platform for high-quality custom printing solutions. From precise tags to durable labels and bulk business orders, Rida delivers tailored perfection, fast turnaround, and seamless online ordering.",
    technologies: "Modern Web Stack",
    client: "Rida",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/Rida.pdf",
    image: "/products/Rida.webp",
  },
  {
    category: "Training & Certification",
    name: "Vertigoo",
    desc: "A premier IRATA and work-at-height training program provider in GCC & India. Vertigoo features accredited courses, professional job placements, and a state-of-the-art training center.",
    technologies: "EdTech, Modern Web Stack",
    client: "Vertigoo",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/VERTIGOO.pdf",
    image: "/products/Vertigoo.webp",
  },
  {
    category: "Immigration Consulting",
    name: "Ask Kubeir",
    desc: "A comprehensive Canadian immigration platform offering expert guidance and seamless processing. Ask Kubeir supports aspirants seeking temporary or permanent residency, Express Entry, and connects Canadian employers with global talent.",
    technologies: "Modern Web Stack",
    client: "Ask Kubeir",
    status: "Design / Concept",
    pdfLink: "/ui&pdf/WhiteHorseLandingPage.pdf",
    image: "/products/whitehorse.webp",
  },
];
---

<Layout
  title="Portfolio & Case Studies"
  description="Real client success stories: e-commerce, AI talent ecosystems, 3D websites, custom CRMs, aviation portals and digital transformations built end-to-end."
  keywords="software development portfolio, web development case studies, custom CRM examples, e-commerce development portfolio, 3D website portfolio, digital transformation case studies, aviation website, AI talent platform"
>
  <div class="page-wrapper">
    <Navbar />

    <section class="solutions-showcase">
      <div class="container">
        
        <div class="showcase-header">
          <h1 class="showcase-title">Client Success Stories</h1>
          <p class="showcase-subtitle">
            A selection of <a href="/custom-software-development/">custom software</a> and <a href="/saas-development-company/">SaaS platforms</a> we've shipped.
          </p>
        </div>


        <div class="showcase-list">
          {projects.map((project) => {
            return (
              <div class="showcase-card" style="cursor: pointer;"
                   data-name={project.name}
                   data-category={project.category}
                   data-desc={project.desc}
                   data-tech={project.technologies}
                   data-client={project.client}
                   data-status={project.status || ""}
                   data-link={project.link || ""}
                   data-pdf={project.pdfLink || ""}
                   data-image={project.image}>
                <div class="card-visual">
                  <div class="card-img-wrapper">
                    <img src={project.image} alt={project.name} loading="lazy" />
                    <div class="card-img-overlay"></div>
                  </div>
                </div>
                
                <div class="card-content">
                  <h3 class="card-name">{project.name}</h3>
                  <p class="card-desc">{project.desc}</p>
                </div>
              </div>
            );
          })}
        </div>

        <div class="coming-soon-projects">
          <h3>More Case Studies Coming Soon ✨</h3>
          <p>We are continuously working with our clients to deliver cutting-edge solutions. Stay tuned as we update our portfolio with more recent successes.</p>
        </div>

      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bottom-cta">
      <div class="container">
        <h2>Ready to build something amazing?</h2>
        <p>Your business could be our next big success story. Let's discuss your requirements and see how we can help.</p>
        <a href="/contact" class="btn btn-primary btn-xl">Get Started</a>
      </div>
    </section>

    <Footer />
  </div>

  <!-- Dynamic Project Preview Modal -->
  <div class="project-modal" id="project-modal">
    <div class="modal-backdrop" id="modal-backdrop"></div>
    <div class="modal-window">
      <div class="modal-iframe-container">
        <div class="browser-mockup">
          <div class="browser-chrome">
            <div class="chrome-dots">
              <span class="chrome-dot red"></span>
              <span class="chrome-dot yellow"></span>
              <span class="chrome-dot green"></span>
            </div>
            <div class="chrome-url" id="modal-chrome-url">n3global.tech</div>
          </div>
          <div class="browser-content">
            <div class="iframe-loading-indicator">
              <div class="spinner"></div>
              <span>Loading preview...</span>
            </div>
            <iframe id="modal-iframe" src="" frameborder="0"></iframe>
            <div id="modal-image-fallback" class="image-fallback">
              <img id="modal-fallback-img" src="" alt="" />
            </div>
          </div>
        </div>
      </div>
      <div class="modal-sidebar">
        <button class="modal-close" id="modal-close" aria-label="Close modal">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        
        <div class="sidebar-header">
          <h2 id="modal-title" class="sidebar-title">Project Title</h2>
          <div class="sidebar-avatar-row">
            <div class="sidebar-avatar" id="modal-avatar">N</div>
            <div class="sidebar-author-info">
              <span class="sidebar-author-label">by <span class="sidebar-client">Client Name</span></span>
              <span class="sidebar-verified" title="Verified Project">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#3b82f6" stroke="#ffffff" stroke-width="2.5" style="margin-left: 2px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0110 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0114 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>
              </span>
            </div>
          </div>
        </div>

        <div class="sidebar-actions">
          <a id="modal-btn-live" href="" target="_blank" rel="noopener noreferrer" class="sidebar-btn btn-primary-action">
            Preview Site
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left: 4px;"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5L21 3m0 0h-5.25m5.25 0v5.25m-9 13.5H3.75A2.25 2.25 0 011.5 19.5V8.25a2.25 2.25 0 012.25-2.25h5.25" /></svg>
          </a>
          <a id="modal-btn-ui" href="" target="_blank" rel="noopener noreferrer" class="sidebar-btn btn-secondary-action">
            View UI Design
          </a>
        </div>

        <div class="sidebar-body">
          <h3 class="section-title">About this website</h3>
          <div id="modal-tags" class="sidebar-tags">
            <!-- Tags go here dynamically -->
          </div>
          <p id="modal-desc" class="sidebar-description">Project description goes here...</p>
          
          <div class="sidebar-details-box">
            <p><strong>Technologies:</strong> <span id="modal-tech">Tech list</span></p>
            <p><strong>Status:</strong> <span id="modal-status">Status</span></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Light theme container */
  .page-wrapper {
    background-color: #ffffff !important;
    color: #0f172a !important;
    min-height: 100vh;
  }

  .solutions-showcase {
    padding: calc(60px + 3rem) 0 6rem;
    font-family: var(--font-body);
  }

  .showcase-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .showcase-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #0f172a !important;
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
  }

  .showcase-subtitle {
    max-width: 680px;
    margin: 0 auto;
    color: #475569;
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .showcase-subtitle a {
    color: #0369a1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* Showcase List Grid */
  .showcase-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .showcase-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%;
  }

  .showcase-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.06);
    border-color: #cbd5e1;
  }

  /* Image block */
  .card-visual {
    width: 100%;
    overflow: hidden;
    position: relative;
    background: #ffffff;
  }

  .card-img-wrapper {
    position: relative;
    width: 100%;
    padding-top: 66.67%; /* 3:2 aspect ratio */
    overflow: hidden;
  }

  .card-img-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .showcase-card:hover img {
    transform: scale(1.04);
  }

  .card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.04), transparent);
    pointer-events: none;
  }

  /* Content block */
  .card-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 1.25rem;
  }

  .card-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.35rem;
    line-height: 1.25;
  }

  .card-desc {
    font-size: 0.88rem;
    color: #64748b;
    line-height: 1.5;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  /* Coming Soon Section */
  .coming-soon-projects {
    text-align: center;
    padding: 4rem 2rem;
    margin-top: 6rem;
    background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    border-radius: 1.5rem;
    border: 1px dashed #cbd5e1;
  }

  .coming-soon-projects h3 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .coming-soon-projects p {
    color: #64748b;
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Bottom CTA */
  .bottom-cta {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid #f1f5f9;
    background: #fafafa;
  }

  .bottom-cta h2 {
    color: #0f172a;
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .bottom-cta p {
    color: #64748b;
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .showcase-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .solutions-showcase {
      padding: calc(60px + 1.5rem) 0 4rem;
    }
    .showcase-title {
      font-size: 2.5rem;
      margin-bottom: 2rem;
    }
    .showcase-list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* Industry Context */
  .industry-context {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    padding: 2.5rem;
    max-width: 800px;
    margin: 0 auto 5rem auto;
    text-align: center;
  }
  .industry-context h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
  }
  .industry-context p {
    color: #475569;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
  }

  /* Project Modal Overlay */
  .project-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2.5rem;
  }

  .project-modal.modal-active {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: opacity 0.3s ease;
  }

  .modal-window {
    position: relative;
    width: 95vw;
    height: 88vh;
    max-width: 1450px;
    max-height: 900px;
    background: #f8fafc; /* premium light gray behind cards */
    border-radius: 1.75rem;
    box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.25);
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    overflow: hidden;
    z-index: 10;
    border: 1px solid #e2e8f0;
    animation: modalScaleUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes modalScaleUp {
    from {
      transform: scale(0.95);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .modal-iframe-container {
    flex: 1;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .browser-mockup {
    width: 100%;
    height: 100%;
    background: #ffffff;
    border-radius: 1.25rem;
    box-shadow: 0 10px 30px -10px rgba(15, 23, 42, 0.12), 0 1px 3px rgba(15, 23, 42, 0.04);
    border: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .browser-chrome {
    height: 44px;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
    position: relative;
    flex-shrink: 0;
  }

  .chrome-dots {
    display: flex;
    gap: 6px;
    position: absolute;
    left: 1.25rem;
  }

  .chrome-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .chrome-dot.red { background: #ef4444; }
  .chrome-dot.yellow { background: #f59e0b; }
  .chrome-dot.green { background: #10b981; }

  .chrome-url {
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    font-size: 0.78rem;
    color: #64748b;
    padding: 3px 2.5rem;
    min-width: 220px;
    max-width: 420px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 500;
  }

  .browser-content {
    flex: 1;
    position: relative;
    background: #ffffff;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .browser-content iframe {
    width: 100%;
    height: 100%;
    border: 0;
    background: #ffffff;
  }

  .iframe-loading-indicator {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: #64748b;
    font-size: 0.95rem;
    font-weight: 600;
    pointer-events: none; /* prevent click interception */
    z-index: 15;
  }

  .spinner {
    width: 36px;
    height: 36px;
    border: 3.5px solid #e2e8f0;
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .image-fallback {
    position: absolute;
    inset: 0;
    background: #f8fafc;
    display: block;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 0;
  }

  .image-fallback img {
    width: 100%;
    height: auto;
    display: block;
  }

  .modal-sidebar {
    width: 420px;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 1.25rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 10px 30px -10px rgba(15, 23, 42, 0.12), 0 1px 3px rgba(15, 23, 42, 0.04);
    position: relative;
  }

  .modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    color: #64748b;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    z-index: 20;
  }

  .modal-close:hover {
    background: #f1f5f9;
    color: #0f172a;
    transform: scale(1.05);
  }

  .sidebar-header {
    padding: 2.5rem 2rem 1.5rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .sidebar-title {
    font-family: var(--font-heading);
    font-size: 1.45rem;
    font-weight: 800;
    color: #0f172a;
    line-height: 1.25;
    margin-bottom: 0.75rem;
    padding-right: 2.5rem;
  }

  .sidebar-avatar-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sidebar-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #3b82f6;
    color: #ffffff;
    font-weight: 700;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
  }

  .sidebar-author-info {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .sidebar-author-label {
    font-size: 0.85rem;
    color: #475569;
    font-weight: 600;
  }

  .sidebar-verified {
    display: inline-flex;
    align-items: center;
  }

  .sidebar-actions {
    padding: 1.25rem 2rem;
    display: flex;
    gap: 0.75rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .sidebar-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.2s ease;
    text-align: center;
  }

  .btn-primary-action {
    background: #3b82f6; /* template blue matching reference */
    color: #ffffff;
    border: 1px solid transparent;
  }

  .btn-primary-action:hover {
    background: #2563eb;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
  }

  .btn-secondary-action {
    background: #ffffff;
    color: #1e293b;
    border: 1px solid #cbd5e1;
  }

  .btn-secondary-action:hover {
    background: #f8fafc;
    color: #0f172a;
    border-color: #94a3b8;
  }

  .sidebar-body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-body::-webkit-scrollbar {
    width: 6px;
  }
  .sidebar-body::-webkit-scrollbar-track {
    background: transparent;
  }
  .sidebar-body::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 3px;
  }
  .sidebar-body::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  .sidebar-body .section-title {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 800;
    color: #0f172a;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .sidebar-tag-chip {
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.3rem 0.75rem;
    background: #f1f5f9;
    color: #475569;
    border-radius: 99px;
  }

  .sidebar-description {
    font-size: 0.92rem;
    color: #475569;
    line-height: 1.65;
    margin: 0;
  }

  .sidebar-details-box {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 1rem;
    font-size: 0.85rem;
    color: #64748b;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .sidebar-details-box p {
    margin: 0;
  }

  .sidebar-details-box strong {
    color: #334155;
  }

  .sidebar-footer {
    padding: 1.25rem 2rem;
    border-top: 1px solid #f1f5f9;
    background: #ffffff;
  }

  .chat-input-wrapper {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 99px;
    padding: 0.25rem 0.25rem 0.25rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    transition: all 0.2s ease;
  }

  .chat-input-wrapper:focus-within {
    border-color: #3b82f6;
