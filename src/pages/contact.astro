---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact & Hire Developers"
  description="Ready to start your software project? Tell us your idea and get a tailored proposal within 24 hours. Web, mobile, AI, cloud and custom software development."
  keywords="hire software developers, contact software development company, get software quote, software project consultation, hire web developers, hire mobile app developers"
>
  <Navbar />

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero__glow"></div>
    <div class="page-hero__bg-dots"></div>
    <div class="container page-hero__inner">
      <div class="badge badge-sky">Contact Us</div>
      <h1 class="page-hero__title">
        Let's Build Something <span class="text-gradient">Great Together</span>
      </h1>
      <p class="page-hero__desc">
        Whether you need <a href="/custom-software-development/">custom software</a>, a <a href="/saas-development-company/">SaaS platform</a>, or a mobile app, we're ready to listen. Share your idea or workflow problem and we'll respond within 24 hours with a tailored proposal.
      </p>
    </div>
  </section>

  <!-- Contact section -->
  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- Info side -->
        <div class="contact-info">
          <h2>Get In Touch</h2>
          <p class="contact-info__desc">
            Whether you have a fully defined project or just a vague idea, we're here to help. Our team will analyze your requirements and respond with a thoughtful proposal.
          </p>

          <!-- Contact details -->
          <div class="contact-details">
            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="var(--sky-500)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="contact-detail__label">Email</div>
                <a href="mailto:contact@n3global.tech" class="contact-detail__value">contact@n3global.tech</a>
              </div>
            </div>

            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="var(--sky-500)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <div class="contact-detail__label">Phone</div>
                <a href="tel:+919645091256" class="contact-detail__value">+91 96450 91256</a>
              </div>
            </div>

            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="var(--sky-500)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <div class="contact-detail__label">Office</div>
                <address class="contact-detail__value">
                  TK Junction, Near Capital Mall,<br />
                  Thana, Kannur, Kerala 670002, India
                </address>
              </div>
            </div>

            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#25d366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413"/></svg>
              </div>
              <div>
                <div class="contact-detail__label">WhatsApp</div>
                <a href="https://wa.me/919645091256?text=Hi%20N3%20Global%20Tech%2C%20I%27d%20like%20to%20discuss%20a%20project." target="_blank" rel="noopener noreferrer" class="contact-detail__value">+91 96450 91256</a>
              </div>
            </div>

            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="var(--sky-500)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <div class="contact-detail__label">Response Time</div>
                <span class="contact-detail__value">Within 24 hours</span>
              </div>
            </div>
          </div>

          <!-- Why contact us -->
          <div class="contact-reasons">
            <h3>Why Work With Us?</h3>
            <ul>
              {[
                "Free initial consultation",
                "Transparent project scoping",
                "Dedicated project manager",
                "Flexible engagement models",
                "NDA available on request",
              ].map(r => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--sky-500)" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  {r}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Form side -->
        <div class="contact-form-wrap">
          <form class="contact-form" id="contact-form" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="first-name">First Name <span class="req">*</span></label>
                <input type="text" id="first-name" name="first_name" placeholder="John" required />
              </div>
              <div class="form-group">
                <label for="last-name">Last Name <span class="req">*</span></label>
                <input type="text" id="last-name" name="last_name" placeholder="Doe" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email Address <span class="req">*</span></label>
              <input type="email" id="email" name="email" placeholder="john@company.com" required />
            </div>

            <div class="form-group">
              <label for="company">Company / Organization</label>
              <input type="text" id="company" name="company" placeholder="Acme Corp" />
            </div>

            <div class="form-group">
              <label for="service">Service Interested In <span class="req">*</span></label>
              <select id="service" name="service" required>
                <option value="" disabled selected>Select a service...</option>
                <option value="web">Web Development</option>
                <option value="mobile">Mobile App Development</option>
                <option value="cloud">Cloud Solutions & DevOps</option>
                <option value="ai">AI & Automation</option>
                <option value="security">Cybersecurity</option>
                <option value="consulting">IT Consulting</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div class="form-group">
              <label for="budget">Estimated Budget</label>
              <select id="budget" name="budget">
                <option value="" disabled selected>Select a range...</option>
                <option value="under10k">Under ₹10,000</option>
                <option value="10k-20k">₹10,000 – ₹20,000</option>
                <option value="20k-50k">₹20,000 – ₹50,000</option>
                <option value="50k-1L">₹50,000 – ₹1 Lakh</option>
                <option value="1L-2L">₹1 Lakh – ₹2 Lakhs</option>
                <option value="2L+">₹2 Lakhs+</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Tell Us About Your Project <span class="req">*</span></label>
              <textarea id="message" name="message" rows="5" placeholder="Describe your project, goals, timeline, or any questions you have..." required></textarea>
            </div>

            <div class="form-group form-group--checkbox">
              <label class="checkbox-label">
                <input type="checkbox" id="nda" name="nda" />
                <span>I'd like to sign an NDA before discussing project details</span>
              </label>
            </div>

            <!-- Honeypot: invisible to humans, bots tend to fill every field -->
            <div class="hp-field" aria-hidden="true">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <button type="submit" class="btn btn-primary btn-submit" id="submit-btn">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              <span class="btn-submit__label">Send Message</span>
            </button>

            <p class="form-note">We take your privacy seriously. No spam, ever.</p>

            <!-- Error message -->
            <div class="form-error" id="form-error" role="alert" hidden>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span id="form-error-text">Something went wrong. Please try again or email us at contact@n3global.tech.</span>
            </div>

            <!-- Success message -->
            <div class="form-success" id="form-success" aria-live="polite">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--sky-500)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <h3>Message Sent!</h3>
              <p>Thank you for reaching out. Our team will review your message and get back to you within 24 hours.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map / Location -->
  <section class="section-sm map-section">
    <div class="container">
      <div class="map-wrap">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3902.0!2d75.3704!3d11.8745!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sTK%20Junction%2C%20Thana%2C%20Kannur%2C%20Kerala%20670002!5e0!3m2!1sen!2sin!4v1700000000000"
          width="100%"
          height="380"
          style="border:0; border-radius: 1rem;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="N3 Global Tech office location at TK Junction, Thana, Kannur, Kerala"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container">
      <div class="section-header">
        <div class="badge badge-sky">FAQ</div>
        <h2>Frequently Asked <span class="text-gradient">Questions</span></h2>
      </div>

      <div class="faq-grid">
        {[
          {
            q: "How long does a typical project take?",
            a: "Project timelines vary greatly depending on scope and complexity. A simple web app might take 4–8 weeks, while an enterprise platform could take 6–12 months. We provide detailed timelines during the scoping phase."
          },
          {
            q: "Do you work with startups?",
            a: "Absolutely. We love working with startups and offer flexible engagement models. We can help with MVP development, technical co-founding roles, or full product teams."
          },
          {
            q: "What technologies do you specialize in?",
            a: "Our stack covers React, Next.js, Node.js, Python, Flutter, AWS, GCP, Azure, PostgreSQL, and many more. We always choose the best tool for your specific use case."
          },
          {
            q: "Can we start with a small pilot project?",
            a: "Yes! A pilot or proof-of-concept is often a great way for us to work together, demonstrate our capabilities, and establish trust before committing to a larger engagement."
          },
          {
            q: "Do you provide support after launch?",
            a: "Yes. We offer ongoing maintenance, monitoring, updates, and feature development. We can structure a retainer agreement to ensure your product stays healthy and evolving."
          },
          {
            q: "How does pricing work?",
            a: "We offer fixed-price projects for well-defined scopes, and time-and-materials for flexible engagements. Pricing depends on team size, timeline, and technology requirements."
          },
        ].map(faq => (
          <div class="faq-card">
            <h4 class="faq-q">{faq.q}</h4>
            <p class="faq-a">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    padding: calc(72px + 5rem) 0 5rem;
    background: var(--white);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-hero__bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, var(--sky-200) 1px, transparent 1px);
    background-size: 36px 36px;
    opacity: 0.25;
    pointer-events: none;
  }
  .page-hero__glow {
    position: absolute;
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(14,165,233,0.12) 0%, transparent 70%);
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }
  .page-hero__inner { position: relative; z-index: 2; }
  .page-hero__inner .badge { margin-bottom: 1.25rem; }
  .page-hero__title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }
  .page-hero__desc {
    color: var(--gray-500);
    font-size: 1.1rem;
    line-height: 1.8;
    max-width: 640px;
    margin: 0 auto;
  }
  .page-hero__desc a {
    color: var(--sky-700);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Contact layout */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 5rem;
    align-items: start;
  }

  /* Info side */
  .contact-info h2 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .contact-info__desc {
    color: var(--gray-500);
    line-height: 1.8;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .contact-detail {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-detail__icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: var(--radius-md);
    background: var(--sky-50);
    border: 1px solid var(--sky-100);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-detail__label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-400);
    margin-bottom: 0.25rem;
  }

  .contact-detail__value {
    font-size: 0.9rem;
    color: var(--gray-700);
    font-weight: 500;
    line-height: 1.55;
    transition: color 0.2s;
    font-style: normal;
    margin: 0;
  }

  a.contact-detail__value:hover { color: var(--primary); }

  .map-section { padding-top: 0; }
  .map-wrap {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .map-wrap iframe { display: block; }

  .contact-reasons {
    background: var(--gray-50);
    border-radius: var(--radius-xl);
    border: 1px solid var(--gray-100);
    padding: 1.5rem;
  }

  .contact-reasons h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gray-700);
    margin-bottom: 1rem;
    font-family: var(--font-heading);
  }

  .contact-reasons ul {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .contact-reasons li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: var(--gray-600);
    font-weight: 500;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--gray-100);
    box-shadow: var(--shadow-xl);
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gray-700);
  }

  .req { color: var(--sky-700); }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--gray-800);
    background: var(--white);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder { color: var(--gray-300); }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(14,165,233,0.12);
  }

  .form-group--checkbox {
    flex-direction: row;
    align-items: center;
  }

  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    cursor: pointer;
    font-size: 0.875rem !important;
    font-weight: 400 !important;
    color: var(--gray-600) !important;
  }

  .checkbox-label input[type="checkbox"] {
    width: 18px;
    height: 18px;
    min-width: 18px;
    accent-color: var(--primary);
    margin-top: 1px;
    cursor: pointer;
  }

  .btn-submit {
    width: 100%;
    justify-content: center;
    padding: 0.875rem 1.75rem !important;
    font-size: 1rem !important;
    gap: 0.6rem;
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
  }

  .form-note {
    text-align: center;
    font-size: 0.78rem;
    color: var(--gray-400);
    margin-top: -0.5rem;
  }

  .form-success {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 2rem;
    background: var(--sky-50);
    border-radius: var(--radius-lg);
    border: 1px solid var(--sky-100);
  }

  .form-success h3 {
    font-size: 1.25rem;
    color: var(--gray-900);
  }

  .form-success p {
    color: var(--gray-500);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .form-success.visible {
    display: flex;
  }

  /* Honeypot — visually hidden but accessible */
  .hp-field {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* Error message */
  .form-error {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: var(--radius-md);
    color: #b91c1c;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .form-error[hidden] {
    display: none;
  }
  .form-error svg {
    flex-shrink: 0;
  }

  /* FAQ */
  .faq-section { background: var(--gray-50); }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .faq-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--gray-100);
    padding: 1.75rem;
    transition: var(--transition);
  }

  .faq-card:hover {
    border-color: var(--sky-100);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .faq-q {
    font-size: 1rem;
    font-weight: 700;
    color: var(--gray-900);
    margin-bottom: 0.75rem;
    font-family: var(--font-heading);
  }

  .faq-a {
    font-size: 0.875rem;
    color: var(--gray-500);
    line-height: 1.75;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .faq-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 500px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: 1.75rem; }
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('contact-form');
    var successMsg = document.getElementById('form-success');
    var errorMsg = document.getElementById('form-error');
    var errorText = document.getElementById('form-error-text');
    var submitBtn = document.getElementById('submit-btn');
    var submitLabel = submitBtn ? submitBtn.querySelector('.btn-submit__label') : null;

    if (!form || !successMsg || !errorMsg || !submitBtn || !submitLabel) return;

    function showError(text) {
      errorText.textContent = text || 'Something went wrong. Please try again or email us at contact@n3global.tech.';
      errorMsg.hidden = false;
      errorMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function clearError() {
      errorMsg.hidden = true;
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      clearError();

      // Honeypot: bots fill this, humans never see it
      var hp = form.querySelector('#website');
      if (hp && hp.value) return;

      var data = new FormData(form);
      var firstName = (data.get('first_name') || '').toString().trim();
      var lastName = (data.get('last_name') || '').toString().trim();
      var email = (data.get('email') || '').toString().trim();
      var message = (data.get('message') || '').toString().trim();
      var service = (data.get('service') || '').toString();

      if (!firstName || !lastName) {
        showError('Please enter your name.');
        return;
      }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError('Please enter a valid email address.');
        return;
      }
      if (!service) {
        showError('Please select a service.');
        return;
      }
      if (!message || message.length < 10) {
        showError('Please tell us a bit more about your project (at least 10 characters).');
        return;
      }

      submitBtn.disabled = true;
      submitLabel.textContent = 'Sending...';

      try {
        // POST to our own server endpoint (token stays server-side)
        var res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            first_name: firstName,
            last_name: lastName,
            email: email,
            phone: null,
            company: (data.get('company') || '').toString().trim() || null,
            service_interest: service,
            budget_range: (data.get('budget') || '').toString() || null,
            message: message,
            nda_requested: data.get('nda') === 'on',
            metadata: {
              referrer: document.referrer || null,
            },
          }),
        });

        var body;
        try { body = await res.json(); } catch (_) { body = {}; }

        if (!res.ok || body.success === false) {
          var msg = body && body.message ? body.message : 'Submission failed. Please try again.';
          showError(msg);
          submitBtn.disabled = false;
          submitLabel.textContent = 'Send Message';
          return;
        }

        form.style.display = 'none';
        successMsg.classList.add('visible');
      } catch (err) {
        console.error('Contact form submit error:', err);
        showError('We could not reach our servers. Please try again or email contact@n3global.tech.');
        submitBtn.disabled = false;
        submitLabel.textContent = 'Send Message';
      }
    });
  })();
</script>
