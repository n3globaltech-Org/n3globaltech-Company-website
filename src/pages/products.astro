---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    tag: "Vehicle Management",
    name: "N3 Service Book",
    desc: "A comprehensive vehicle service management software that streamlines bookings, service tracking, invoicing, and customer management for auto service businesses.",
    technologies: "React, Node.js, PostgreSQL, Tailwind CSS",
    client: "AutoServe Garage",
    date: "12 Oct 2024",
    image: "/products/n3_service_book_icon.png",
  },

  {
    tag: "Gym Management",
    name: "N3 Fit",
    desc: "An AI-powered gym management platform designed for modern fitness businesses, simplifying memberships, automating schedules, optimizing trainer assignments, and managing attendance and payments effortlessly.",
    technologies: "React, React Native, Node.js, MongoDB",
    client: "Elite Fitness Studios, AzeeFit",
    date: "15 Mar 2025",
    image: "/products/n3_fit_icon.png",
  },
  {
    tag: "Full-Stack Web Application",
    name: "N3 Wedding Card",
    desc: "A full-stack digital wedding invitation platform that transforms traditional invitations into interactive web experiences.",
    technologies: "React.js, Node.js, PostgreSQL",
    client: "Independent Couples",
    date: "20 May 2025",
    image: "/products/n3_wedding_card_icon.png",
  },
  {
    tag: "Invoicing Software",
    name: "N3 Invoice",
    desc: "A complete invoicing platform purpose-built for small-scale businesses. Create professional invoices, track payments, manage clients, and send reminders — all in one place.",
    technologies: "React, Firebase, Stripe API",
    client: "Freelancer Hub",
    date: "08 Jul 2025",
    image: "/products/n3_invoice_icon.png",
  }
];
---

<Layout title="Our Products" description="Explore N3 Global Tech's suite of software products.">
  <div class="page-wrapper">
    <Navbar />

    <main class="main-content">
      <div class="container-narrow">
        
        <!-- Featured Section -->
        <section class="featured-section">
          <div class="featured-left">
            <span class="meta-tag uppercase">Featured</span>
            <h1 class="featured-title">Something big is coming...<br />A new era for work</h1>
            
            <div class="meta-row">
              <span class="meta-date">Launch 2026</span>
              <span class="meta-tag">Product</span>
            </div>
            
            <a href="/contact" class="btn-pill">Get Early Access</a>
          </div>
          
          <div class="featured-right">
            <div class="featured-image-wrapper">
              <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" alt="Coming Soon" class="featured-image" />
            </div>
          </div>
        </section>

        <!-- Section Title -->
        <div class="section-header">
          <h2 class="section-title">Our Products</h2>
        </div>

        <!-- Product Grid -->
        <section class="product-grid">
          {products.map((product) => (
            <div class="product-card">
              <div class="card-content">
                <h2 class="card-title">{product.name}</h2>
                <div class="meta-row">
                  <span class="meta-date">{product.date}</span>
                  <span class="meta-tag">Product</span>
                </div>
                <a href="/contact" class="btn-pill">Read blog</a>
              </div>
              <div class="card-image-wrapper">
                <img src={product.image} alt={product.name} class="card-image" loading="lazy" />
              </div>
            </div>
          ))}
        </section>

      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  /* Base Overrides for this layout */
  .page-wrapper {
    background-color: #ffffff !important;
    color: #111827 !important;
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    letter-spacing: -0.01em;
  }

  .main-content {
    padding: calc(68px + 3rem) 2rem 6rem;
  }

  .container-narrow {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Typography specific to minimal Google layout */
  .meta-tag, .meta-date {
    font-size: 0.85rem;
    color: #6b7280;
    font-weight: 500;
  }

  .meta-tag.uppercase {
    text-transform: none; /* In Google design "Featured" is proper case */
    color: #374151;
  }

  .meta-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    align-items: center;
  }

  .btn-pill {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    background-color: #f3f4f6;
    color: #111827;
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .btn-pill:hover {
    background-color: #e5e7eb;
  }

  /* Featured Section */
  .featured-section {
    display: flex;
    gap: 4rem;
    align-items: center;
    margin-bottom: 4rem;
  }

  .featured-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .featured-left > .meta-tag {
    margin-bottom: 1.5rem;
  }

  .featured-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 400; /* Thin, elegant font weight based on images */
    line-height: 1.1;
    color: #111827;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .featured-right {
    flex: 1.2;
  }

  .featured-image-wrapper {
    background-color: #000;
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8; /* Stylized darkness */
  }

  /* Product Grid */
  .product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* Exactly 2 columns to match reference */
    gap: 3rem 2rem; 
    margin: 0;
    padding: 0;
  }

  .product-card {
    display: flex;
    flex-direction: row;
    justify-content: flex-start;
    align-items: flex-start;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    margin: 0;
    width: 100%;
  }

  .card-content {
    flex: 1;
    padding-right: 1.5rem;
    margin: 0;
  }

  .card-image-wrapper {
    width: 140px;
    height: 140px; 
    flex-shrink: 0;
    aspect-ratio: 1 / 1; 
    background-color: #000;
    border-radius: 1rem;
    overflow: hidden;
    margin: 0;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
  }

  .card-title {
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 0.5rem;
    color: #111827;
  }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    .main-content {
      padding-top: 40px; /* Reduced top gap for mobile */
    }

    .featured-section {
      flex-direction: column;
      text-align: left;
      margin-bottom: 25px; 
      gap: 1.5rem;
    }

    .featured-right {
      width: 100%;
    }

    .product-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .product-card {
      flex-direction: column; 
    }

    .card-content {
      padding-right: 0;
      width: 100%;
      order: 2; /* Content second */
    }

    .card-image-wrapper {
      width: 160px; 
      height: 160px;
      margin: 0 0 1rem 0;
      order: 1; /* Image first */
      align-self: flex-start; /* Force left align */
    }
  }

  /* Section Title Spacing */
  .section-header {
    margin: 0 0 1rem 0;
    padding: 0;
  }
  
  .section-title {
    font-size: 1.8rem;
    font-weight: 500;
    color: #111827;
    letter-spacing: -0.02em;
    padding-bottom: 0.5rem;
    margin: 0;
    text-align: left; /* Force left align to fix centering */
    border-bottom: 1px solid #e5e7eb;
  }
</style>
