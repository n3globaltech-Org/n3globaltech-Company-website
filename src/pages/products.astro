---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    tag: "Community Marketplace",
    name: "Circle for Work",
    desc: "A hyperlocal community trust platform connecting local service providers, rentals, and skilled workers with neighbors for everyday jobs, products, and equipment sharing.",
    technologies: "React, Next.js, Node.js, PostgreSQL",
    client: "Local Communities",
    date: "Launch 2026",
    image: "/circleforwork.jpeg",
    imageBg: "#ffffff",
    imageFit: "contain",
    link: "/products/circle-for-work/",
  },
  {
    tag: "Vehicle Management",
    name: "N3 ServiceBook",
    desc: "A comprehensive vehicle service management software that streamlines bookings, service tracking, invoicing, and customer management for auto service businesses.",
    technologies: "React, Node.js, PostgreSQL, Tailwind CSS",
    client: "AutoServe Garage",
    date: "12 Oct 2024",
    image: "/products/ServiceBook.svg",
    imageBg: "#ffffff",
    imageFit: "contain",
    link: "https://www.n3servicebook.in/",
  },
  {
    tag: "Gym Management",
    name: "N3 FitBook",
    desc: "An AI-powered gym management platform designed for modern fitness businesses, simplifying memberships, automating schedules, optimizing trainer assignments, and managing attendance and payments effortlessly.",
    technologies: "React, React Native, Node.js, MongoDB",
    client: "Elite Fitness Studios, AzeeFit",
    date: "15 Mar 2025",
    image: "/products/FitBook.svg",
    link: "https://www.n3fitbook.in/",
  },
  {
    tag: "Business Management",
    name: "N3 BusinessBook",
    desc: "An all-in-one business management platform that streamlines operations, finances, clients, and team workflows for small to mid-sized businesses.",
    technologies: "React.js, Node.js, PostgreSQL",
    client: "Small & Mid-Sized Businesses",
    date: "20 May 2025",
    image: "/products/BusinessBook.svg",
  }
];
---

<Layout
  title="Our SaaS Products"
  description="Explore our SaaS suite: N3 ServiceBook for vehicle service management, N3 FitBook for gym operations, and N3 BusinessBook for end-to-end business workflows."
  keywords="SaaS products, gym management software, vehicle service software, business management software, N3 ServiceBook, N3 FitBook, N3 BusinessBook, custom SaaS, fitness software, automotive service software"
>
  <div class="page-wrapper">
    <Navbar />

    <main class="main-content">
      <div class="container-narrow">
        
        <!-- Featured Section -->
        <section class="featured-section">
          <div class="featured-left">
            <span class="meta-tag uppercase">Featured</span>
            <h1 class="featured-title">Something big is coming...<br />A new era for work</h1>
            
            <div class="meta-row">
              <span class="meta-date">Launch 2026</span>
              <span class="meta-tag">Product</span>
            </div>
            
            <a href="/products/circle-for-work/" class="btn-pill">Get Early Access</a>
          </div>
          
          <div class="featured-right">
            <div class="featured-image-wrapper">
              <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" alt="Coming Soon" class="featured-image" />
            </div>
          </div>
        </section>

        <!-- Section Title -->
        <div class="section-header">
          <h2 class="section-title">Our Products</h2>
          <p class="section-intro">
            Alongside client projects, we build and operate our own proprietary SaaS platforms and products, serving as a live showcase of what our hybrid <a href="/saas-development-company/">SaaS development company</a> can build for you.
          </p>
        </div>

        <!-- Product Grid -->
        <section class="product-grid">
          {products.map((product) => {
            const isExternal = product.link && product.link.startsWith('http');
            const CardElement = product.link ? 'a' : 'div';
            const extraProps = product.link
              ? { 
                  href: product.link, 
                  ...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}), 
                  class: "product-card product-card--link" 
                }
              : { class: "product-card" };

            return (
              <CardElement {...extraProps}>
                <div class="card-content">
                  <h2 class="card-title">
                    {product.name}
                    {product.link && isExternal && (
                      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="margin-left: 5px; display: inline-block; vertical-align: middle; opacity: 0.8;"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
                    )}
                  </h2>
                  <div class="meta-row">
                    <span class="meta-date">{product.date}</span>
                    <span class="meta-tag">Product</span>
                  </div>
                </div>
                <div class="card-image-wrapper" style={product.imageBg ? `background-color: ${product.imageBg};` : undefined}>
                  <img src={product.image} alt={product.name} class="card-image" loading="lazy" style={product.imageFit ? `object-fit: ${product.imageFit}; padding: 0.75rem;` : undefined} />
                </div>
              </CardElement>
            );
          })}
        </section>

        <!-- Product Engineering Philosophy -->
        <section class="philosophy-section">
          <div class="philosophy-content">
            <h3>Our Product Engineering Philosophy</h3>
            <p>
              We believe the best way to understand the challenges of running a SaaS business is to run one yourself. Our proprietary platforms are built on the exact same multi-tenant cloud architecture, subscription billing logic, and robust <a href="/custom-software-development/">custom software development</a> standards that we bring to our clients' projects. When we build products, we focus on high availability, seamless user onboarding, and enterprise-grade security from day one.
            </p>
          </div>
        </section>

      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  /* Base Overrides for this layout */
  .page-wrapper {
    background-color: #ffffff !important;
    color: #111827 !important;
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    letter-spacing: -0.01em;
  }

  .main-content {
    padding: calc(68px + 3rem) 2rem 6rem;
  }

  .container-narrow {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Typography specific to minimal Google layout */
  .meta-tag, .meta-date {
    font-size: 0.85rem;
    color: #6b7280;
    font-weight: 500;
  }

  .meta-tag.uppercase {
    text-transform: none; /* In Google design "Featured" is proper case */
    color: #374151;
  }

  .meta-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    align-items: center;
  }

  .btn-pill {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    background-color: #f3f4f6;
    color: #111827;
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .btn-pill:hover {
    background-color: #e5e7eb;
  }

  /* Featured Section */
  .featured-section {
    display: flex;
    gap: 4rem;
    align-items: center;
    margin-bottom: 4rem;
  }

  .featured-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .featured-left > .meta-tag {
    margin-bottom: 1.5rem;
  }

  .featured-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 400; /* Thin, elegant font weight based on images */
    line-height: 1.1;
    color: #111827;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .featured-right {
    flex: 1.2;
  }

  .featured-image-wrapper {
    background-color: #000;
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8; /* Stylized darkness */
  }

  /* Product Grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 2rem;
    margin: 0;
    padding: 0;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    text-align: center;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    margin: 0;
    width: 100%;
  }

  .card-content {
    width: 100%;
    padding-right: 0;
    margin: 0;
    order: 2;
  }

  .card-content .meta-row {
    justify-content: center;
  }

  .card-image-wrapper {
    width: 140px;
    height: 140px;
    flex-shrink: 0;
    aspect-ratio: 1 / 1;
    background-color: #000;
    border-radius: 1rem;
    overflow: hidden;
    margin: 0 0 1rem 0;
    order: 1;
    align-self: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
    border-radius: 1rem;
  }

  .product-card--link {
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .product-card--link:hover {
    transform: translateY(-2px);
    border-bottom-color: var(--sky-500);
  }
  .product-card--link:hover .card-image-wrapper {
    transform: scale(1.03);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .card-title {
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 0.5rem;
    color: #111827;
  }

  /* Responsive Adjustments */
  @media (max-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .main-content {
      padding: calc(68px + 2rem) 1.5rem 4rem;
    }

    .featured-section {
      flex-direction: column;
      text-align: left;
      margin-bottom: 25px;
      gap: 1.5rem;
    }

    .featured-right {
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .main-content {
      padding: calc(56px + 1.5rem) 1rem 3rem;
    }

    .philosophy-section {
      padding: 1.5rem 1.25rem;
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
      border-radius: 0.75rem;
    }

    .product-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .card-image-wrapper {
      width: 160px;
      height: 160px;
    }
  }

  /* Section Title Spacing */
  .section-header {
    margin: 0 0 1rem 0;
    padding: 0;
  }
  
  .section-title {
    font-size: 1.8rem;
    font-weight: 500;
    color: #111827;
    letter-spacing: -0.02em;
    padding-bottom: 0.5rem;
    margin: 0;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }

  .section-intro {
    margin: 1.25rem 0 2rem;
    color: #4b5563;
    font-size: 1rem;
    line-height: 1.75;
    max-width: 720px;
  }
  .section-intro a {
    color: #0369a1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Philosophy Section */
  .philosophy-section {
    background: #f8fafc;
    border-radius: 1rem;
    padding: 2.5rem;
    margin-top: 4rem;
    margin-bottom: 4rem;
    border: 1px solid #e2e8f0;
  }
  .philosophy-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 1rem 0;
  }
  .philosophy-content p {
    color: #4b5563;
    line-height: 1.8;
    font-size: 1.05rem;
    margin: 0;
  }
  .philosophy-content a {
    color: #0369a1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
