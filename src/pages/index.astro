    line-height: 1.75;
    font-size: 0.97rem;
    margin: 0;
  }

  .principles-summary {
    max-width: 820px;
    margin: 3rem auto 0;
    padding: 1.75rem 2rem;
    background: var(--sky-50);
    border-radius: var(--radius-md);
  }

  .principles-summary p {
    margin: 0;
    color: var(--gray-700);
    line-height: 1.85;
    font-size: 1rem;
  }

  .principles-summary a {
    color: var(--sky-700);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 900px) {
    .principles-grid { grid-template-columns: 1fr; }
  }

  /* ===== WORK SHOWCASE — STICKY SCROLL ANIMATION ===== */

  /* Scroll track: gives the sticky panel room to animate */
  .ws-scroll-track {
    position: relative;
    height: 230vh;
    background: #ffffff;
  }

  /* Sticky panel fills viewport while track scrolls */
  .ws-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    overflow: hidden;
    background: #ffffff;
  }

  .ws-sticky-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    will-change: transform;
  }

  /* Heading block */
  .ws-heading {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 2rem;
    position: relative;
    z-index: 10;
  }
  .ws-heading h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--gray-900);
    margin: 0.5rem 0;
    line-height: 1.15;
  }
  .ws-heading p {
    color: var(--gray-500);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
    max-width: 520px;
    margin-inline: auto;
  }

  /* Card stage — full available width, centered */
  .ws-stage {
    position: relative;
    width: 100%;
    max-width: 1100px;
    height: 290px;
    flex-shrink: 0;
  }

  /* Individual project cards — flex column: image top, meta bottom */
  .ws-card {
    position: absolute;
    /* size — 390×345 desktop (image + meta), sized by JS */
    width: 390px;
    height: 345px;
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #ffffff;
    border: 1.5px solid rgba(0,0,0,0.07);
    box-shadow:
      0 4px 8px rgba(0,0,0,0.05),
      0 12px 32px rgba(0,0,0,0.10),
      0 28px 60px rgba(0,0,0,0.08);
    will-change: transform;
    transform-origin: center bottom;
    transition: box-shadow 0.35s ease;
    /* JS sets initial stacked transforms */
  }
  .ws-card:hover {
    box-shadow:
      0 8px 16px rgba(0,0,0,0.07),
      0 20px 48px rgba(0,0,0,0.14),
      0 40px 80px rgba(0,0,0,0.10);
  }

  /* Image section — takes all available space above meta */
  .ws-card__img {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    background: var(--gray-100);
  }
  .ws-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s cubic-bezier(0.4,0,0.2,1);
  }
  .ws-card:hover .ws-card__img img {
    transform: scale(1.04);
  }

  /* Subtle dark overlay on hover — removed */

  /* Meta panel — white text section below image */
  .ws-card__meta {
    flex-shrink: 0;
    padding: 0.85rem 1rem 0.9rem;
    background: #ffffff;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .ws-card__name {
    display: block;
    font-size: 0.92rem;
    font-weight: 800;
    color: var(--gray-900);
    line-height: 1.3;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ws-card__desc {
    margin: 0;
    font-size: 0.78rem;
    color: var(--gray-500);
    line-height: 1.45;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* CTA */
  .ws-cta {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
    position: relative;
    z-index: 5;
  }
  .ws-cta.ws-visible {
    opacity: 1;
    transform: translateY(0);
  }


  /* Mobile */
  @media (max-width: 760px) {
    .ws-scroll-track { height: 300vh; }   /* more room for vertical card deal & camera pan */
    .ws-sticky { justify-content: flex-start; padding-top: 2.5rem; }
    .ws-heading { margin-bottom: 1.25rem; flex-shrink: 0; }
    .ws-stage { height: 830px; }          /* 3 × 250px + 16px gaps × 2 + buffer */
    .ws-card { width: 280px; height: 250px; border-radius: 14px; }
    .ws-labels { grid-template-columns: 1fr; gap: 0.6rem; margin-top: 1.25rem; }
    .ws-card__meta { padding: 0.7rem 0.85rem 0.75rem; }
    .ws-card__name { font-size: 0.85rem; }
    .ws-card__desc { font-size: 0.72rem; }
  }




  /* ===== ABOUT PREVIEW ===== */
  .about-preview {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    padding: 5rem 0;
  }

  .about-preview__inner {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1080px;
    margin: 0 auto;
  }

  .about-preview__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 1rem 0 1.25rem;
    color: var(--gray-900);
  }

  .about-preview__desc {
    color: var(--gray-600);
    font-size: 1.02rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 560px;
  }

  .about-preview__visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .founders-stack {
    display: flex;
    align-items: center;
  }

  .founder-mini {
    width: 78px;
    height: 78px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, #38bdf8, #0284c7);
    box-shadow: 0 4px 14px rgba(0,0,0,0.08);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .founder-mini:not(:first-child) {
    margin-left: -18px;
  }
  .founder-mini:hover {
    transform: translateY(-4px) scale(1.05);
    z-index: 2;
  }
  .founder-mini--violet { background: linear-gradient(135deg, #a78bfa, #7c3aed); }
  .founder-mini--teal   { background: linear-gradient(135deg, #2dd4bf, #0d9488); }
  .founder-mini--amber  { background: linear-gradient(135deg, #fbbf24, #d97706); }

  .founder-mini img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    background: #ffffff;
  }
  .founder-mini--initial {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .founder-mini--initial span {
    width: calc(100% - 6px);
    height: calc(100% - 6px);
    border-radius: 50%;
    background: inherit;
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: 1.65rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .founders-stack__caption {
    font-size: 0.85rem;
    color: var(--gray-500);
    font-weight: 500;
    text-align: center;
    margin: 0;
  }

  @media (max-width: 900px) {
    .about-preview__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }
    .about-preview__desc {
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    .about-preview { padding: 3.5rem 0; }
  }

  /* ===== HOW IT WORKS ===== */
  .how-it-works {
    background: var(--white);
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .process-interactive-layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    max-width: 1100px;
    margin: 4rem auto 0 auto;
    position: relative;
    align-items: start;
  }

  .process-steps-column {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .process-step {
    display: block;
    cursor: pointer;
    opacity: 0.35;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 1.5rem 0;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--gray-150, rgba(226, 232, 240, 0.8));
    background: transparent !important;
  }

  .process-step:hover {
    opacity: 0.7;
    background: transparent !important;
  }

  .process-step.active {
    opacity: 1;
    background: transparent !important;
    border-bottom: 1px solid var(--gray-150, rgba(226, 232, 240, 0.8));
  }

  .step-progress-indicator {
    display: none;
  }

  .step-content {
    width: 100%;
  }

  .step-title {
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--gray-900);
    margin-bottom: 0;
    transition: color 0.3s ease;
  }

  .process-step.active .step-title {
    color: var(--gray-900);
  }

  .step-desc-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, margin-top 0.4s ease;
    opacity: 0;
  }

  .process-step.active .step-desc-wrapper {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: 0.75rem;
  }

  .step-desc {
    overflow: hidden;
    font-size: 0.925rem;
    color: var(--gray-600);
    line-height: 1.6;
  }

  /* Horizontal Process Progress Bar */
  .process-progress-horizontal {
    width: 100%;
    height: 2px;
    background: var(--gray-150, rgba(226, 232, 240, 0.8));
    position: relative;
    margin-bottom: 2rem;
    border-radius: 2px;
  }

  .process-progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 33.33%;
    background: var(--sky-600);
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 2px;
  }

  /* Visual container styling */
  .process-visual-container {
    position: sticky;
    top: 150px;
    height: 400px;
    background: linear-gradient(135deg, rgba(2, 132, 199, 0.02) 0%, rgba(99, 102, 241, 0.02) 100%);
    border: 1px solid rgba(2, 132, 199, 0.08);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.05),
      0 2px 4px -1px rgba(0, 0, 0, 0.03),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.6);
  }

  .sticky-visual-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .process-visual-card {
    position: absolute;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transform: scale(0.96) translateY(10px);
    pointer-events: none;
    transition: all 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process-visual-card.active {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  /* Mockup specific UI styles */

  /* 1. Inquiry Form Mockup */
  .inquiry-form-mockup {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    box-shadow: 
      0 10px 25px -5px rgba(0, 0, 0, 0.05),
      0 8px 10px -6px rgba(0, 0, 0, 0.03);
    max-width: 340px;
    width: 100%;
  }

  .mockup-header {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--gray-100);
    padding-bottom: 0.6rem;
  }

  .mockup-field {
    margin-bottom: 1.1rem;
  }

  .mockup-field label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .type-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .type-chips .chip {
    font-size: 0.725rem;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--gray-200);
    color: var(--gray-500);
    font-weight: 500;
  }

  .type-chips .chip.active {
    background: linear-gradient(135deg, var(--sky-500), var(--sky-600));
    color: var(--white);
    border-color: transparent;
    box-shadow: 0 2px 4px rgba(2, 132, 199, 0.15);
  }

  .description-typewriter {
    font-size: 0.775rem;
    color: var(--gray-700);
    background: var(--gray-50);
    border-radius: var(--radius-md);
    padding: 0.6rem;
    border: 1px solid var(--gray-100);
    font-family: monospace;
    line-height: 1.4;
  }

  .slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gray-700);
    margin-bottom: 0.4rem;
  }

  .slider-track {
    height: 5px;
    background: var(--gray-100);
    border-radius: 3px;
    position: relative;
  }

  .slider-fill {
    position: absolute;
    left: 0;
    right: 40%;
    height: 100%;
    background: var(--sky-500);
    border-radius: 3px;
  }

  .slider-thumb {
    position: absolute;
    left: 60%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 12px;
    height: 12px;
    background: var(--white);
    border: 2px solid var(--sky-500);
    border-radius: 50%;
  }

  .mockup-submit-btn {
    width: 100%;
    padding: 0.7rem;
    background: linear-gradient(135deg, var(--sky-500), var(--sky-600));
    color: var(--white);
    border: none;
    border-radius: var(--radius-md);
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 0.4rem;
    box-shadow: 0 4px 10px rgba(2, 132, 199, 0.15);
    opacity: 0.9;
  }

  /* 2. Design + Dev workflow */
  .workflow-mockup {
    display: flex;
    gap: 0.75rem;
    width: 100%;
    max-width: 420px;
    height: 280px;
  }

  .workflow-left, .workflow-right {
    flex: 1;
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 
      0 10px 25px -5px rgba(0, 0, 0, 0.04),
      0 8px 10px -6px rgba(0, 0, 0, 0.02);
  }

  .editor-header {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--gray-400);
    background: var(--gray-50);
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--gray-100);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .figma-canvas {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.75rem;
    gap: 0.5rem;
    background: #f8fafc;
  }

  .canvas-node {
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.4rem;
    border-radius: 4px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    color: var(--gray-400);
    text-align: center;
  }

  .canvas-node.active-node {
    border-color: var(--sky-500);
    color: var(--sky-600);
    background: rgba(2, 132, 199, 0.02);
    position: relative;
    font-weight: 600;
  }

  .node-border {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--white);
    border: 1px solid var(--sky-500);
  }

  .border-tl { top: -2.5px; left: -2.5px; }
  .border-tr { top: -2.5px; right: -2.5px; }
  .border-bl { bottom: -2.5px; left: -2.5px; }
  .border-br { bottom: -2.5px; right: -2.5px; }

  .node-tag {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.5rem;
    background: var(--sky-500);
    color: var(--white);
    padding: 1px 4px;
    border-radius: 2px;
    font-weight: 600;
    white-space: nowrap;
  }

  .code-editor {
    flex: 1;
    background: #0f172a;
    padding: 0.6rem;
    font-family: monospace;
    font-size: 0.6rem;
    line-height: 1.4;
    color: #cbd5e1;
    overflow: hidden;
  }

  .code-editor pre {
    margin: 0;
  }

  .code-keyword { color: #f43f5e; }
  .code-string { color: #10b981; }
  .code-func { color: #3b82f6; }
  .code-tag { color: #38bdf8; }
  .code-bool { color: #f59e0b; }

  .workflow-terminal {
    background: #020617;
    padding: 0.4rem 0.6rem;
    font-family: monospace;
    font-size: 0.55rem;
    border-top: 1px solid #1e293b;
    color: #94a3b8;
  }

  .term-line {
    margin-bottom: 0.15rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* 3. Launch & Grow dashboard */
  .dashboard-mockup {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 1.25rem;
    box-shadow: 
      0 10px 25px -5px rgba(0, 0, 0, 0.05),
      0 8px 10px -6px rgba(0, 0, 0, 0.03);
    max-width: 340px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .dashboard-stats {
    display: flex;
    gap: 0.5rem;
  }

  .stat-card {
    flex: 1;
    background: var(--gray-50);
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-md);
    padding: 0.5rem;
  }

  .stat-title {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.15rem;
  }

  .stat-value {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gray-800);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-trend {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 10px;
  }

  .stat-trend.trend-up {
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
  }

  .dashboard-chart-container {
    height: 100px;
    display: flex;
    align-items: flex-end;
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-md);
    background: var(--gray-50);
    padding: 0.5rem;
    overflow: hidden;
  }

  .dashboard-chart {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .dashboard-footer {
    border-top: 1px solid var(--gray-100);
    padding-top: 0.5rem;
    font-size: 0.7rem;
    color: var(--gray-500);
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 50%;
  }

  .pulsing {
    box-shadow: 0 0 0 rgba(16, 185, 129, 0.4);
    animation: status-pulse 2s infinite;
  }

  @keyframes status-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    }
    70% {
      box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
    }
  }

  /* Responsive styles */
  @media (max-width: 1024px) {
    .how-it-works {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .process-interactive-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .process-steps-column {
      gap: 0;
    }

    .process-step {
      display: block;
      padding: 1.25rem 0;
      border-radius: 0;
      border: none;
      border-bottom: 1px solid var(--gray-150, rgba(226, 232, 240, 0.8));
      background: transparent !important;
      opacity: 0.35;
      transition: opacity 0.4s ease;
    }

    .process-step.active {
      opacity: 1;
      background: transparent !important;
      border-bottom: 1px solid var(--gray-150, rgba(226, 232, 240, 0.8));
    }

    .step-progress-indicator {
      display: none;
    }

    .step-title {
      font-size: 1.35rem;
    }

    .process-visual-container {
      display: none;
    }
  }

  .launch-demo__dot {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 50%;
