<script is:inline>
(function () {
  /* ============================================================
     Work Showcase — Sticky scroll-linked card animation
     Cards animate from stacked/rotated → side-by-side
     as the user scrolls through the 230vh .ws-scroll-track.
  ============================================================ */

  function lerp(a, b, t) { return a + (b - a) * t; }
  function easeInOutCubic(t) {
    return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2,3)/2;
  }
  function clamp(v,lo,hi) { return Math.max(lo,Math.min(hi,v)); }
  const isMobile = () => window.innerWidth <= 760;

  // Returns card dimensions + stacked/final position configs
  function getConfig() {
    const m   = isMobile();
    const cW  = m ? 260 : 340;   // mobile: full-ish width; desktop: 3-col
    const cH  = m ? 250 : 300;   // taller cards to fit image + meta text panel
    const gap = m ? 16  : 28;

    if (m) {
      // Mobile: cards deal out VERTICALLY (top → center → bottom)
      const vspan = cH + gap;
      return {
        cW, cH, n: 3,
        stacked: [
          { x: -cW*0.06, y:  cH*0.04, r: -5,  z: 4, s: 1.00 },
          { x:  cW*0.08, y: -cH*0.03, r:  7,  z: 3, s: 0.94 },
          { x:  cW*0.20, y: -cH*0.07, r:  14, z: 2, s: 0.86 },
        ],
        final: [
          { x: 0, y: -vspan, r: 0, z: 2, s: 1.00 },  // TOP
          { x: 0, y:      0, r: 0, z: 1, s: 1.00 },  // MIDDLE
          { x: 0, y: +vspan, r: 0, z: 0, s: 1.00 },  // BOTTOM
        ],
      };
    }

    // Desktop: cards deal out HORIZONTALLY (left → center → right)
    const span = cW + gap;
    return {
      cW, cH, n: 3,
      stacked: [
        { x: -cW*0.08, y:  cH*0.04, r: -5,  z: 4, s: 1.00 },
        { x:  cW*0.10, y: -cH*0.03, r:  7,  z: 3, s: 0.94 },
        { x:  cW*0.26, y: -cH*0.07, r:  15, z: 2, s: 0.86 },
      ],
      final: [
        { x: -span, y: 0, r: 0, z: 2, s: 1.00 },   // LEFT
        { x:     0, y: 0, r: 0, z: 1, s: 1.00 },   // CENTER
        { x: +span, y: 0, r: 0, z: 0, s: 1.00 },   // RIGHT
      ],
    };
  }

  function applyCards(progress) {
    const cfg = getConfig();
    const p   = easeInOutCubic(clamp(progress, 0, 1));
    for (let i = 0; i < cfg.n; i++) {
      const el = document.getElementById('ws-card-'+i);
      if (!el) continue;
      const s = cfg.stacked[i], f = cfg.final[i];
      const x  = lerp(s.x, f.x, p);
      const y  = lerp(s.y, f.y, p);
      const r  = lerp(s.r, f.r, p);
      const sc = lerp(s.s, f.s, p);
      el.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px)) rotate(${r}deg) scale(${sc})`;
      el.style.zIndex = String(Math.round(lerp(s.z, f.z, p)));
    }
  }

  function setSizes() {
    const cfg = getConfig();
    for (let i = 0; i < cfg.n; i++) {
      const el = document.getElementById('ws-card-'+i);
      if (el) { el.style.width = cfg.cW+'px'; el.style.height = cfg.cH+'px'; }
    }
    const stage = document.getElementById('ws-stage');
    if (stage) {
      // Mobile: stage must be tall enough for 3 vertical cards
      // Desktop: single card height + padding
      const m = isMobile();
      const gap = m ? 16 : 28;
      const stageH = m
        ? cfg.cH * 3 + gap * 2 + 48   // 3 cards stacked + gaps + buffer
        : cfg.cH + 48;
      stage.style.height = stageH + 'px';
    }
  }

  let track, cta, lastP = -1;

  function onScroll() {
    track = track || document.getElementById('ws-scroll-track');
    cta   = cta   || document.getElementById('ws-cta');
    if (!track) return;

    const scrollY    = window.scrollY || window.pageYOffset;
    const winH       = window.innerHeight;
    const trackTop   = track.getBoundingClientRect().top + scrollY;
    const scrollable = track.offsetHeight - winH;
    const raw        = scrollable > 0 ? clamp((scrollY - trackTop) / scrollable, 0, 1) : 1;
    if (Math.abs(raw - lastP) < 0.0005) return;
    lastP = raw;

    applyCards(raw);

    if (raw > 0.88) {
      cta && cta.classList.add('ws-visible');
    } else {
      cta && cta.classList.remove('ws-visible');
    }
  }

  function init() {
    const cfg = getConfig();
    // Position all 3 cards from center of stage
    for (let i = 0; i < cfg.n; i++) {
      const el = document.getElementById('ws-card-'+i);
      if (el) { el.style.top = '50%'; el.style.left = '50%'; el.style.position = 'absolute'; }
    }
    setSizes();
    applyCards(0); // set initial stacked state
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { setSizes(); onScroll(); });
    onScroll();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.ws-card');
    const modal = document.getElementById('project-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const closeBtn = document.getElementById('modal-close');
    const iframe = document.getElementById('modal-iframe');
    const chromeUrl = document.getElementById('modal-chrome-url');
    const fallbackContainer = document.getElementById('modal-image-fallback');
    const fallbackImg = document.getElementById('modal-fallback-img');
    
    const mTitle = document.getElementById('modal-title');
    const mAvatar = document.getElementById('modal-avatar');
    const mClient = document.querySelector('.sidebar-client');
    const mDesc = document.getElementById('modal-desc');
    const mTech = document.getElementById('modal-tech');
    const mStatus = document.getElementById('modal-status');
    const mTags = document.getElementById('modal-tags');
    const btnLive = document.getElementById('modal-btn-live');
    const btnUI = document.getElementById('modal-btn-ui');
    const loadingIndicator = document.querySelector('.iframe-loading-indicator');
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        
        const name = card.getAttribute('data-name');
        const category = card.getAttribute('data-category');
        const desc = card.getAttribute('data-desc');
        const tech = card.getAttribute('data-tech');
        const client = card.getAttribute('data-client');
        const status = card.getAttribute('data-status');
        const link = card.getAttribute('data-link');
        const pdf = card.getAttribute('data-pdf');
        const image = card.getAttribute('data-image');
        
        if (!name) return;
        
        // Populate fields
        mTitle.textContent = name;
        mClient.textContent = client || '';
        mDesc.textContent = desc;
        mTech.textContent = tech || 'Modern Web Stack';
        mStatus.textContent = status || 'Live';
        
        // Set avatar letter
        if (client) {
          mAvatar.textContent = client.trim().charAt(0).toUpperCase();
        } else {
          mAvatar.textContent = 'N';
        }
        
        // Tags
        mTags.innerHTML = '';
        if (category) {
          category.split('&').forEach(t => {
            const span = document.createElement('span');
            span.className = 'sidebar-tag-chip';
            span.textContent = t.trim();
            mTags.appendChild(span);
          });
        }
        
        // Set buttons
        if (link) {
          btnLive.href = link;
          btnLive.style.display = 'inline-flex';
        } else {
          btnLive.style.display = 'none';
        }
        
        if (pdf) {
          btnUI.href = pdf;
          btnUI.style.display = 'inline-flex';
        } else {
          btnUI.style.display = 'none';
        }
        
        const isMobile = window.innerWidth <= 1024;
        const interactiveUrl = link || pdf;
        const useImageFallback = !interactiveUrl || isMobile;
        
        if (!useImageFallback) {
          iframe.style.display = 'block';
          fallbackContainer.style.display = 'none';
          loadingIndicator.style.display = 'flex';
          iframe.src = interactiveUrl;
          
          try {
            chromeUrl.textContent = new URL(interactiveUrl).hostname;
          } catch (_) {
            if (interactiveUrl.endsWith('.pdf')) {
              chromeUrl.textContent = interactiveUrl.substring(interactiveUrl.lastIndexOf('/') + 1);
            } else {
              chromeUrl.textContent = interactiveUrl;
            }
          }
        } else {
          iframe.style.display = 'none';
          loadingIndicator.style.display = 'none';
          fallbackContainer.style.display = 'block';
          fallbackImg.src = image;
          
          if (pdf) {
            chromeUrl.textContent = pdf.substring(pdf.lastIndexOf('/') + 1);
          } else {
            chromeUrl.textContent = name;
          }
        }
        
        // Open modal
        modal.classList.add('modal-active');
        document.body.style.overflow = 'hidden';
      });
    });

    iframe.addEventListener('load', () => {
      loadingIndicator.style.display = 'none';
    });

    function closeModal() {
      modal.classList.remove('modal-active');
      document.body.style.overflow = '';
      iframe.src = '';
    }

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  });
</script>

