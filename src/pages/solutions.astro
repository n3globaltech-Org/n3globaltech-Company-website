---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    tag: "Vehicle Management",
    name: "N3 Book",
    desc: "A comprehensive vehicle service management software that streamlines bookings, service tracking, invoicing, and customer management for auto service businesses.",
    features: ["Service Booking", "Vehicle History", "Invoice Generation", "Customer CRM", "Staff Management", "Reminders & Alerts"],
    status: "Live",
    color: "sky",
    icon: `<svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h.01M12 7h.01M16 7h.01M3 12h18M3 12a9 9 0 1018 0 9 9 0 00-18 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 17l1.5-3h7L17 17"/></svg>`,
  },
  {
    tag: "Personal Finance",
    name: "N3 Pfin",
    desc: "A complete personal finance tracker that helps individuals manage budgets, track expenses, set savings goals, and gain full control of their financial health.",
    features: ["Expense Tracking", "Budget Planner", "Savings Goals", "Visual Analytics", "Bank Sync", "Multi-Currency"],
    status: "Live",
    color: "violet",
    icon: `<svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    tag: "Gym Management",
    name: "N3 Fit",
    desc: "A powerful gym management solution built for fitness businesses — manage memberships, class schedules, trainer assignments, attendance, and payments effortlessly.",
    features: ["Membership Plans", "Class Scheduling", "Trainer Management", "Attendance Tracking", "Payment Processing", "Progress Reports"],
    status: "Live",
    color: "teal",
    icon: `<svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12h1m16 0h1M5.6 5.6l.7.7m12.4 12.4l-.7-.7M12 3v1m0 16v1m-6.4-5.6l-.7.7M18.4 5.6l.7.7"/><circle cx="12" cy="12" r="4"/></svg>`,
  },
  {
    tag: "Accounting Software",
    name: "N3 Acc",
    desc: "A complete accounting software designed for small to mid-size businesses — manage ledgers, generate financial reports, handle GST/tax compliance, and keep your books clean.",
    features: ["General Ledger", "GST & Tax Reports", "Profit & Loss", "Balance Sheet", "Multi-Branch", "Role-Based Access"],
    status: "Live",
    color: "amber",
    icon: `<svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  },
  {
    tag: "Invoicing Software",
    name: "N3 Invoice",
    desc: "A complete invoicing platform purpose-built for small-scale businesses. Create professional invoices, track payments, manage clients, and send reminders — all in one place.",
    features: ["Invoice Builder", "Payment Tracking", "Client Management", "Recurring Invoices", "PDF Export", "Overdue Alerts"],
    status: "Live",
    color: "rose",
    icon: `<svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  },
  {
    tag: "Flagship Product",
    name: "Circle for Work",
    desc: "Our flagship platform for freelancers and vendors. Find clients, manage projects, sell products, and grow your independent business — all from one powerful hub.",
    features: ["Freelancer Dashboard", "Vendor Storefront", "Project Management", "Payments & Escrow", "Reviews & Ratings", "Analytics"],
    status: "Coming Soon",
    color: "indigo",
    icon: `<svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 14s1.5 2 4 2 4-2 4-2"/><circle cx="9" cy="10" r="1" fill="currentColor"/><circle cx="15" cy="10" r="1" fill="currentColor"/></svg>`,
  },
];

const statusColors: Record<string, string> = {
  "Live": "status--green",
  "Beta": "status--blue",
  "Coming Soon": "status--gray",
};
---

<Layout title="Our Solutions" description="Explore N3 Global Tech's suite of software products — N3 Book, N3 Pfin, N3 Fit, N3 Acc, N3 Invoice, and Circle for Work.">
  <Navbar />

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero__glow"></div>
    <div class="page-hero__bg-dots"></div>
    <div class="container page-hero__inner">
      <div class="badge badge-sky">Our Solutions</div>
      <h1 class="page-hero__title">
        Products Built for <br />
        <span class="text-gradient">Modern Business</span>
      </h1>
      <p class="page-hero__desc">
        Beyond custom projects, we build and maintain our own suite of software solutions — ready to deploy and adapt to your needs.
      </p>
    </div>
  </section>

  <!-- Products -->
  <section class="section">
    <div class="container">
      <div class="products-grid">
        {products.map((product) => (
          <div class={`product-card product-card--${product.color}`}>
            <div class="product-card__header">
              <div class={`product-card__icon product-card__icon--${product.color}`} set:html={product.icon} />
              <div class="product-card__meta">
                <span class="product-tag">{product.tag}</span>
                <span class={`product-status ${statusColors[product.status]}`}>{product.status}</span>
              </div>
            </div>

            <h3 class="product-card__name">{product.name}</h3>
            <p class="product-card__desc">{product.desc}</p>

            <div class="product-card__features">
              {product.features.map(f => (
                <span class="feature-chip">{f}</span>
              ))}
            </div>

            <div class="product-card__footer">
              <a href="/contact" class={`btn product-btn product-btn--${product.color}`}>
                {product.status === "Coming Soon" ? "Join Waitlist" : "Learn More"}
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <a href="/contact" class="btn-text-link">Request Demo →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom Solution CTA -->
  <section class="section-sm custom-cta">
    <div class="container">
      <div class="custom-cta__inner">
        <div class="custom-cta__label">
          <div class="badge badge-sky">Custom Build</div>
        </div>
        <h2>Need a Tailored Solution?</h2>
        <p>Don't see exactly what you're looking for? We specialize in building custom software from the ground up — designed exactly for your unique needs and workflows.</p>
        <div class="custom-cta__btns">
          <a href="/contact" class="btn btn-primary btn-lg">Build Custom Solution</a>
          <a href="/services" class="btn btn-outline btn-lg">View Services</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Page hero */
  .page-hero {
    padding: calc(72px + 5rem) 0 5rem;
    background: var(--white);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .page-hero__bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, var(--sky-200) 1px, transparent 1px);
    background-size: 36px 36px;
    opacity: 0.25;
    pointer-events: none;
  }

  .page-hero__glow {
    position: absolute;
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(14,165,233,0.12) 0%, transparent 70%);
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .page-hero__inner {
    position: relative;
    z-index: 2;
  }

  .page-hero__inner .badge { margin-bottom: 1.25rem; }

  .page-hero__title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .page-hero__desc {
    color: var(--gray-500);
    font-size: 1.1rem;
    line-height: 1.8;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Products grid */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .product-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--gray-100);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }

  .product-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity 0.25s;
    border-radius: 3px 3px 0 0;
  }

  .product-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .product-card:hover::after { opacity: 1; }

  .product-card--sky:hover { border-color: var(--sky-200); }
  .product-card--sky::after { background: var(--sky-500); }
  .product-card--violet:hover { border-color: #ddd6fe; }
  .product-card--violet::after { background: #8b5cf6; }
  .product-card--teal:hover { border-color: #99f6e4; }
  .product-card--teal::after { background: #14b8a6; }
  .product-card--amber:hover { border-color: #fde68a; }
  .product-card--amber::after { background: #f59e0b; }
  .product-card--rose:hover { border-color: #fecdd3; }
  .product-card--rose::after { background: #f43f5e; }
  .product-card--indigo:hover { border-color: #c7d2fe; }
  .product-card--indigo::after { background: #6366f1; }

  .product-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .product-card__icon {
    width: 64px;
    height: 64px;
    min-width: 64px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card__icon--sky { background: var(--sky-50); color: var(--sky-600); }
  .product-card__icon--violet { background: #f5f3ff; color: #7c3aed; }
  .product-card__icon--teal { background: #f0fdfa; color: #0d9488; }
  .product-card__icon--amber { background: #fffbeb; color: #d97706; }
  .product-card__icon--rose { background: #fff1f2; color: #e11d48; }
  .product-card__icon--indigo { background: #eef2ff; color: #4f46e5; }

  .product-card__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .product-tag {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-400);
  }

  .product-status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .product-status::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .status--green {
    background: #f0fdf4;
    color: #15803d;
  }
  .status--green::before { background: #22c55e; }

  .status--blue {
    background: var(--sky-50);
    color: var(--sky-700);
  }
  .status--blue::before { background: var(--sky-500); }

  .status--gray {
    background: var(--gray-100);
    color: var(--gray-500);
  }
  .status--gray::before { background: var(--gray-400); }

  .product-card__name {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--gray-900);
  }

  .product-card__desc {
    color: var(--gray-500);
    font-size: 0.9rem;
    line-height: 1.75;
    flex: 1;
  }

  .product-card__features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .feature-chip {
    padding: 0.3rem 0.75rem;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gray-600);
    transition: var(--transition);
  }

  .product-card:hover .feature-chip {
    background: var(--sky-50);
    border-color: var(--sky-100);
    color: var(--sky-700);
  }

  .product-card__footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--gray-100);
    margin-top: auto;
  }

  .product-btn {
    padding: 0.6rem 1.35rem !important;
    font-size: 0.875rem !important;
  }

  .product-btn--sky { background: var(--sky-500); color: white; }
  .product-btn--violet { background: #8b5cf6; color: white; }
  .product-btn--teal { background: #14b8a6; color: white; }
  .product-btn--amber { background: #f59e0b; color: white; }
  .product-btn--rose { background: #f43f5e; color: white; }
  .product-btn--indigo { background: #6366f1; color: white; }

  .product-btn:hover { transform: translateY(-2px); opacity: 0.9; }

  .btn-text-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gray-500);
    transition: color 0.2s;
  }

  .btn-text-link:hover { color: var(--primary); }

  /* Custom CTA */
  .custom-cta {
    background: var(--gray-50);
    border-top: 1px solid var(--gray-100);
    border-bottom: 1px solid var(--gray-100);
  }

  .custom-cta__inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .custom-cta__inner h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 1rem 0;
  }

  .custom-cta__inner p {
    color: var(--gray-500);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .custom-cta__btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 1100px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 700px) {
    .products-grid { grid-template-columns: 1fr; }
  }
</style>
