---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: "web",
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    color: "sky",
    title: "Web Development",
    desc: "We craft modern, performant, and beautiful web experiences that convert visitors into customers. From landing pages to complex enterprise platforms.",
    features: ["React / Next.js / Astro", "Progressive Web Apps", "E-Commerce Solutions", "CMS Integration", "Performance Optimization", "SEO-First Architecture"],
  },
  {
    id: "mobile",
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
    color: "violet",
    title: "Mobile App Development",
    desc: "Native iOS/Android and cross-platform apps built with Flutter and React Native. We deliver apps that feel seamless and perform beautifully.",
    features: ["React Native / Flutter", "iOS & Android Native", "Offline-First Design", "Push Notifications", "App Store Optimization", "Real-Time Features"],
  },
  {
    id: "cloud",
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    color: "teal",
    title: "Cloud Solutions",
    desc: "Design, migration, and management of cloud infrastructure across AWS, Google Cloud, and Azure. Scale with confidence and control costs.",
    features: ["Cloud Migration", "Kubernetes & Docker", "CI/CD Pipelines", "Serverless Architecture", "Cost Optimization", "Multi-Cloud Strategy"],
  },
  {
    id: "ai",
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    color: "amber",
    title: "AI & Automation",
    desc: "Leverage the power of artificial intelligence to automate operations, gain insights, and create intelligent products that scale.",
    features: ["Machine Learning Models", "LLM / ChatGPT Integration", "RPA Automation", "Predictive Analytics", "Computer Vision", "NLP Solutions"],
  },
  {
    id: "consulting",
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    color: "indigo",
    title: "IT Consulting",
    desc: "Strategic technology consulting that aligns your digital infrastructure with your business vision. We help you make the right tech decisions.",
    features: ["Digital Strategy", "Tech Stack Review", "Architecture Design", "Vendor Selection", "Team Augmentation", "Technology Roadmaps"],
  },
];
const faqs = [
  {
    question: "Do you only provide services, or do you build your own products?",
    answer: "We are a hybrid company. While we build custom software and SaaS platforms for our clients, we also engineer and operate our own proprietary SaaS products like N3 ServiceBook and N3 FitBook. This dual approach ensures we stay sharp on production-level operations, security, and scalability.",
  },
  {
    question: "What is your primary technology stack?",
    answer: "We are framework-agnostic but heavily favor modern, battle-tested technologies. For the frontend, we use React, Next.js, and Astro. For backend APIs, we rely on Node.js and scalable databases like PostgreSQL and MongoDB. For mobile, we build native-feeling apps using React Native and Flutter.",
  },
  {
    question: "Do you work with startups or established enterprises?",
    answer: "Both. We help founders build scalable MVPs from scratch, and we assist established enterprises in modernizing legacy systems, migrating to the cloud, and implementing digital transformation strategies.",
  },
  {
    question: "How do you handle project pricing and scoping?",
    answer: "We offer multiple engagement models. For well-defined scopes, we provide fixed-price contracts with clear milestones. For ongoing development or scaling SaaS platforms, we offer dedicated team retainers. We usually start with a paid discovery phase to map out the exact requirements and select the best model.",
  }
];
---

<Layout
  title="Software Development Services | Web, Mobile, Cloud & AI"
  description="End-to-end software development services from a Kerala-based team serving clients globally. Custom software, SaaS, web apps, mobile apps, cloud, AI/ML and digital transformation."
  keywords="software development services, custom software development, SaaS development, web development services, mobile app development services, cloud services, AI development services, software development Kerala, software company India"
  faqs={faqs}
>
  <Navbar />

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero__glow"></div>
    <div class="container page-hero__inner">
      <div class="badge badge-sky">Our Services</div>
      <h1 class="page-hero__title">
        Technology Services <br class="hide-sm" />
        <span class="text-gradient">Built for Impact</span>
      </h1>
      <p class="page-hero__desc">
        We are a hybrid <strong>product + service</strong> company building <a href="/custom-software-development/">custom software</a>, <a href="/saas-development-company/">SaaS platforms</a>, web applications, and mobile apps for businesses in Kerala, India, and globally. Every solution we ship is scalable, performance-focused, responsive, and user-centric.
      </p>
    </div>
    <div class="page-hero__bg-dots"></div>
  </section>

  <!-- Featured services -->
  <section class="section-sm featured-services">
    <div class="container">
      <h2 class="featured-services__title">Featured services</h2>
      <div class="featured-services__grid">
        <a href="/custom-software-development/" class="featured-card">
          <div class="featured-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <h3>Custom Software Development</h3>
          <p>Tailored web apps, mobile apps, internal tools, and business automation systems.</p>
          <span class="featured-card__link">Learn more →</span>
        </a>
        <a href="/saas-development-company/" class="featured-card">
          <div class="featured-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
          </div>
          <h3>SaaS Development Company</h3>
          <p>Multi-tenant SaaS platforms with subscription billing, integrations, and cloud scale.</p>
          <span class="featured-card__link">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Services List -->
  <section class="section services-page">
    <div class="container">
      <div class="services-list">
        {services.map((service, i) => (
          <div class={`svc-block svc-block--${service.color} ${i % 2 === 1 ? 'svc-block--reverse' : ''}`} id={service.id}>
            <div class="svc-block__visual">
              <div class={`svc-block__icon-wrap svc-block__icon-wrap--${service.color}`} set:html={service.icon} />
              <div class="svc-block__features">
                {service.features.map(f => (
                  <div class="svc-feature">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    {f}
                  </div>
                ))}
              </div>
            </div>
            <div class="svc-block__content">
              <div class={`badge badge-${service.color}`}>{service.title}</div>
              <h2 class="svc-block__title">{service.title}</h2>
              <p class="svc-block__desc">{service.desc}</p>
              <a href="/contact" class="btn btn-primary">
                Get a Quote
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Engagement Models -->
  <section class="section-sm engagement-section">
    <div class="container">
      <div class="section-header">
        <div class="badge badge-sky">How We Work</div>
        <h2>Engagement <span class="text-gradient">Models</span></h2>
        <p>Pick the way of working that fits your project. We're flexible across all three, and most clients shift between them as their needs evolve.</p>
      </div>

      <div class="engagement-grid">
        <article class="engagement-card">
          <div class="engagement-card__icon">
            <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          </div>
          <h3>Fixed-price project</h3>
          <p>Best for clearly scoped builds with a defined deliverable. We share milestones, timeline, and a flat price upfront after a paid discovery call.</p>
          <span class="engagement-card__tag">For: websites, MVPs, single platforms</span>
        </article>

        <article class="engagement-card">
          <div class="engagement-card__icon">
            <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3>Dedicated team</h3>
          <p>Best for ongoing product work, scaling SaaS, or evolving roadmaps. A small team works as part of yours on a monthly retainer with regular sprints.</p>
          <span class="engagement-card__tag">For: SaaS scale-up, long-term partners</span>
        </article>

        <article class="engagement-card">
          <div class="engagement-card__icon">
            <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3>Hourly consulting</h3>
          <p>Best for advisory, code reviews, or short engagements where the scope can't be fixed in advance. Tracked weekly, billed monthly, no minimum commitment.</p>
          <span class="engagement-card__tag">For: tech reviews, expert input, fixes</span>
        </article>
      </div>

      <p class="engagement-note">
        Not sure which fits? Most projects start with a paid discovery call where we map out the right model together. <a href="/contact/">Tell us about your project</a> and we'll suggest the cleanest path.
      </p>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section-sm tech-stack-section">
    <div class="container">
      <div class="section-header">
        <div class="badge badge-sky">Our Stack</div>
        <h2>The <span class="text-gradient">Tools</span> We Build With</h2>
        <p>We pick the right tool for the problem, not the other way around. Here's the stack we use most often across web, mobile, cloud, and SaaS projects.</p>
      </div>

      <div class="tech-grid">
        {[
          ['React', 'Frontend'],
          ['Next.js', 'Full-stack web'],
          ['Astro', 'Marketing & docs'],
          ['Node.js', 'Backend / APIs'],
          ['React Native', 'Mobile cross-platform'],
          ['Flutter', 'Mobile native UI'],
          ['PostgreSQL', 'Relational database'],
          ['MongoDB', 'Document database'],
          ['Firebase', 'Realtime / auth'],
          ['AWS', 'Cloud infrastructure'],
          ['Docker', 'Containers'],
          ['Kubernetes', 'Orchestration'],
        ].map(([name, role]) => (
          <div class="tech-tile">
            <span class="tech-tile__name">{name}</span>
            <span class="tech-tile__role">{role}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section content-section faq-section">
    <div class="container content-narrow">
      <div class="section-header">
        <h2>Frequently <span class="text-gradient">Asked Questions</span></h2>
        <p>Common questions about how we work and the services we provide.</p>
      </div>
      <div class="faq-list">
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.question}</h3>
            <p>{f.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm">
    <div class="container">
      <div class="services-cta-box">
        <div class="services-cta-box__content">
          <h2>Ready to Transform Your Business?</h2>
          <p>Let's discuss exactly what you need and build a plan that works for your goals and budget.</p>
        </div>
        <div class="services-cta-box__actions">
          <a href="/contact" class="btn btn-primary btn-lg">Start a Conversation</a>
          <a href="/work" class="btn btn-ghost btn-lg">See Our Work</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Page hero */
  .page-hero {
    padding: calc(72px + 5rem) 0 5rem;
    background: var(--white);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .page-hero__bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, var(--sky-200) 1px, transparent 1px);
    background-size: 36px 36px;
    opacity: 0.25;
    pointer-events: none;
  }

  .page-hero__glow {
    position: absolute;
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(14,165,233,0.12) 0%, transparent 70%);
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .page-hero__inner {
    position: relative;
    z-index: 2;
  }

  .page-hero__inner .badge { margin-bottom: 1.25rem; }

  .page-hero__title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .page-hero__desc {
    color: var(--gray-500);
    font-size: 1.1rem;
    line-height: 1.8;
    max-width: 680px;
    margin: 0 auto;
  }
  .page-hero__desc a {
    color: var(--sky-700);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hide-sm { display: block; }

  /* Featured services */
  .featured-services { padding-top: 1rem; padding-bottom: 1rem; }
  .featured-services__title {
    text-align: center;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-500);
    margin-bottom: 1.5rem;
  }
  .featured-services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .featured-card {
    display: block;
    background: #ffffff;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
  }
  .featured-card:hover {
    border-color: var(--sky-400);
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(14, 165, 233, 0.12);
  }
  .featured-card__icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--sky-50);
    color: var(--sky-600);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .featured-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--gray-900);
  }
  .featured-card p {
    color: var(--gray-600);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 0.85rem;
  }
  .featured-card__link {
    color: var(--sky-700);
    font-weight: 700;
    font-size: 0.9rem;
  }
  @media (max-width: 700px) {
    .featured-services__grid { grid-template-columns: 1fr; }
  }

  /* Services blocks */
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .svc-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    scroll-margin-top: 100px;
  }

  .svc-block--reverse {
    direction: rtl;
  }

  .svc-block--reverse > * {
    direction: ltr;
  }

  /* Visual side */
  .svc-block__visual {
    background: var(--gray-50);
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--gray-100);
    padding: 2.5rem;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .svc-block__icon-wrap {
    width: 70px;
    height: 70px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .svc-block__icon-wrap--sky { background: var(--sky-50); color: var(--sky-600); }
  .svc-block__icon-wrap--violet { background: #f5f3ff; color: #7c3aed; }
  .svc-block__icon-wrap--teal { background: #f0fdfa; color: #0d9488; }
  .svc-block__icon-wrap--amber { background: #fffbeb; color: #d97706; }
  .svc-block__icon-wrap--rose { background: #fff1f2; color: #e11d48; }
  .svc-block__icon-wrap--indigo { background: #eef2ff; color: #4f46e5; }

  .svc-block__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .svc-feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--gray-600);
    font-weight: 500;
  }

  /* Content side */
  .svc-block__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .svc-block__content .badge {
    width: auto;
  }

  .svc-block__content .btn {
    width: auto;
  }

  .svc-block__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--gray-900);
  }

  .svc-block__desc {
    color: var(--gray-500);
    line-height: 1.8;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  /* Badge colors */
  .badge-sky { background: var(--sky-50); color: var(--sky-700); border: 1px solid var(--sky-100); }
  .badge-violet { background: #f5f3ff; color: #7c3aed; border: 1px solid #ddd6fe; }
  .badge-teal { background: #f0fdfa; color: #0d9488; border: 1px solid #ccfbf1; }
  .badge-amber { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
  .badge-rose { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
  .badge-indigo { background: #eef2ff; color: #4f46e5; border: 1px solid #c7d2fe; }

  /* Engagement models */
  .engagement-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  .engagement-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 1080px;
    margin: 0 auto;
  }
  .engagement-card {
    background: #ffffff;
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 1.85rem 1.6rem;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }
  .engagement-card:hover {
    transform: translateY(-3px);
    border-color: var(--sky-200);
    box-shadow: 0 12px 28px rgba(14, 165, 233, 0.1);
  }
  .engagement-card__icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--sky-50);
    color: var(--sky-700);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .engagement-card h3 {
    font-size: 1.15rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--gray-900);
    letter-spacing: -0.01em;
  }
  .engagement-card p {
    font-size: 0.95rem;
    color: var(--gray-600);
    line-height: 1.65;
    margin: 0 0 1rem;
    flex-grow: 1;
  }
  .engagement-card__tag {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--sky-700);
    background: var(--sky-50);
    padding: 0.4rem 0.75rem;
    border-radius: 9999px;
    align-self: flex-start;
  }
  .engagement-note {
    text-align: center;
    margin-top: 2rem;
    color: var(--gray-600);
    font-size: 0.95rem;
  }
  .engagement-note a {
    color: var(--sky-700);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  @media (max-width: 900px) {
    .engagement-grid { grid-template-columns: 1fr; }
  }

  /* Tech stack */
  .tech-stack-section {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 980px;
    margin: 0 auto;
  }
