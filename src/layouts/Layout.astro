---
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  faqs?: { question: string; answer: string }[];
  article?: {
    headline: string;
    description: string;
    datePublished: string;
    dateModified?: string;
    image?: string;
    author?: string;
  };
  service?: {
    name: string;
    description: string;
    serviceType?: string;
  };
}

const {
  title,
  description = "N3 Global Tech is a custom software development company building scalable web apps, mobile apps, cloud platforms, AI solutions, and SaaS products for startups and enterprises worldwide.",
  keywords = "N3GlobalTech, n3global.tech, n3globaltech, software development company, web development, mobile app development, cloud solutions, SaaS development, custom software, AI development, UI UX design, MVP development, digital transformation, startup tech partner, CRM, ERP, Astro, React, Node.js",
  image = "/og-image.png",
  noindex = false,
  type = 'website',
  faqs,
  article,
  service,
} = Astro.props;

const siteName = "N3 Global Tech";
const alternateSiteName = "N3GlobalTech";
const fullTitle = title.includes(siteName) || title.includes(alternateSiteName) ? title : `${title} | ${siteName} (${alternateSiteName})`;
const siteUrl = Astro.site ?? new URL("https://www.n3global.tech");
const canonicalPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : Astro.url.pathname + '/';
const canonicalUrl = new URL(canonicalPath, siteUrl).href;
const ogImage = new URL(image, siteUrl).href;
const siteUrlString = siteUrl.toString();

// Auto-generate breadcrumbs from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: siteUrlString },
  ...pathSegments.map((seg, idx) => {
    const path = '/' + pathSegments.slice(0, idx + 1).join('/');
    const label = seg.charAt(0).toUpperCase() + seg.slice(1).replace(/-/g, ' ');
    return { name: label, url: new URL(path, siteUrl).href };
  }),
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: item.name,
    item: item.url,
  })),
};

const faqSchema = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
} : null;

const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.headline,
  description: article.description,
  image: article.image ? new URL(article.image, siteUrl).href : ogImage,
  datePublished: article.datePublished,
  dateModified: article.dateModified ?? article.datePublished,
  author: {
    "@type": "Organization",
    name: article.author ?? "N3 Global Tech",
    url: siteUrlString,
  },
  publisher: { "@id": `${siteUrlString}#organization` },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
} : null;

const serviceSchema = service ? {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.name,
  description: service.description,
  serviceType: service.serviceType ?? service.name,
  provider: { "@id": `${siteUrlString}#organization` },
  areaServed: { "@type": "Place", name: "Worldwide" },
  url: canonicalUrl,
} : null;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${siteUrlString}#organization`,
  name: siteName,
  legalName: "N3 Global Tech",
  alternateName: ["N3GlobalTech", "n3globaltech", "n3global.tech", "N3 Global Tech"],
  url: siteUrlString,
  logo: {
    "@type": "ImageObject",
    url: new URL("/n3logo.webp", siteUrl).href,
    width: 512,
    height: 512,
  },
  image: ogImage,
  description: "Custom software development company offering web, mobile, cloud, AI and SaaS product engineering for startups and enterprises.",
  email: "contact@n3global.tech",
  telephone: "+91-9645091256",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "TK Junction, Near Capital Mall, Thana",
    addressLocality: "Kannur",
    addressRegion: "Kerala",
    postalCode: "670002",
    addressCountry: "IN",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 11.8745,
    longitude: 75.3704,
  },
  hasMap: "https://maps.google.com/?q=TK+Junction+Thana+Kannur+Kerala+670002",
  areaServed: [
    { "@type": "Place", name: "Kannur" },
    { "@type": "Place", name: "Kerala" },
    { "@type": "Place", name: "India" },
    { "@type": "Place", name: "Worldwide" },
  ],
  knowsAbout: [
    "Software Development",
    "Web Development",
    "Mobile App Development",
    "Cloud Solutions",
    "Artificial Intelligence",
    "SaaS Development",
    "UI/UX Design",
    "Digital Transformation",
    "MVP Development",
    "CRM",
    "ERP",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Services",
    itemListElement: [
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Web Development", description: "Custom websites & landing pages built with modern frameworks." } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Mobile App Development", description: "iOS, Android and cross-platform mobile applications." } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "UI/UX Design", description: "Wireframes, prototypes, and full design systems." } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "MVP Development", description: "Validate ideas fast with launch-ready MVPs." } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Product Redesign", description: "Modernize legacy products with refreshed UX and tech." } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Digital Marketing", description: "Grow online presence through SEO, content and ads." } },
    ],
  },
  sameAs: [
    "https://www.linkedin.com/company/n3-global-tech",
    "https://www.instagram.com/n3globaltech",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "contact@n3global.tech",
    telephone: "+91-9645091256",
    availableLanguage: ["English"],
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrlString}#website`,
  name: siteName,
  alternateName: ["N3GlobalTech", "n3globaltech", "n3global.tech", "N3 Global Tech"],
  url: siteUrlString,
  publisher: { "@id": `${siteUrlString}#organization` },
  inLanguage: "en-US",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${siteUrlString}?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={siteName} />
    <meta name="theme-color" content="#0ea5e9" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Icons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/webp" href="/n3logo.webp" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Preload LCP candidate (used in navbar on every page) -->
    <link rel="preload" as="image" href="/n3logo.webp" type="image/webp" fetchpriority="high" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Structured Data: Organization (ProfessionalService) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)}></script>
    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)}></script>
    <!-- Structured Data: Breadcrumbs -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)}></script>
    {faqSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>
    )}
    {articleSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)}></script>
    )}
    {serviceSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)}></script>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main id="main-content">
      <slot />
    </main>

    {/* Floating WhatsApp button hidden for now. Uncomment to re-enable. */}
    {false && (
      <a
        href="https://wa.me/919645091256?text=Hi%20N3%20Global%20Tech%2C%20I%27d%20like%20to%20discuss%20a%20project."
        class="wa-fab"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Chat with N3 Global Tech on WhatsApp"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413"/>
        </svg>
        <span class="wa-fab__label">WhatsApp</span>
      </a>
    )}

    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.15 });
        document.querySelectorAll('.reveal').forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --sky-50: #f0f9ff;
    --sky-100: #e0f2fe;
    --sky-200: #bae6fd;
    --sky-300: #7dd3fc;
    --sky-400: #38bdf8;
    --sky-500: #0ea5e9;
    --sky-600: #0284c7;
    --sky-700: #0369a1;
    --sky-800: #075985;
    --sky-900: #0c4a6e;

    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-100: #f1f5f9;
    --gray-200: #e2e8f0;
    --gray-300: #cbd5e1;
    --gray-400: #94a3b8;
    --gray-500: #64748b;
    --gray-600: #475569;
    --gray-700: #334155;
    --gray-800: #1e293b;
    --gray-900: #0f172a;

    --primary: var(--sky-500);
    --primary-dark: var(--sky-600);
    --primary-light: var(--sky-400);
    --primary-pale: var(--sky-50);

    --accent: #f59e0b;
    --accent-dark: #d97706;
    --accent-pale: #fffbeb;

    --font-body: 'Inter', sans-serif;
    --font-heading: 'Instrument Sans', sans-serif;

    --shadow-sm: 0 1px 2px 0 rgba(0,0,0,0.05);
    --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1);
    --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1);
    --shadow-sky: 0 4px 24px rgba(14,165,233,0.18);

    --radius-sm: 0.375rem;
    --radius-md: 0.75rem;
    --radius-lg: 1rem;
    --radius-xl: 1.5rem;
    --radius-full: 9999px;

    --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--white);
    color: var(--gray-800);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: 1.2;
    color: var(--gray-900);
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  img { max-width: 100%; display: block; }

  ul { list-style: none; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--gray-100); }
  ::-webkit-scrollbar-thumb { background: var(--sky-400); border-radius: 99px; }

  /* Utility classes */
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Large screens: increase spacing but cap width */
  @media (min-width: 1440px) {
    .container {
      padding: 0 3rem;
    }
  }

  .section {
    padding: 6rem 0;
  }

  .section-sm {
    padding: 4rem 0;
  }

  /* WhatsApp floating action button */
  .wa-fab {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 95;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.1rem;
    background: #25d366;
    color: #ffffff;
    border-radius: 9999px;
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    box-shadow: 0 12px 28px rgba(37, 211, 102, 0.35), 0 4px 10px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .wa-fab:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 16px 36px rgba(37, 211, 102, 0.45), 0 6px 14px rgba(0, 0, 0, 0.22);
  }
  .wa-fab svg { display: block; }
  @media (max-width: 768px) {
    /* Sticky CTA pill is centered; WhatsApp moves to right and shrinks to icon-only */
    .wa-fab { padding: 0.85rem; bottom: 1rem; right: 1rem; }
    .wa-fab__label { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-fab { transition: none; }
  }

  /* Accessibility: skip-to-content link for keyboard users */
  .skip-link {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 9999;
    padding: 0.65rem 1rem;
    background: var(--gray-900);
    color: #ffffff;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-md);
    transform: translateY(-150%);
    transition: transform 0.18s ease;
  }
  .skip-link:focus {
    transform: translateY(0);
    outline: 3px solid var(--sky-300);
    outline-offset: 2px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.95rem;
    font-family: var(--font-body);
    cursor: pointer;
    border: 2px solid transparent;
    transition: var(--transition);
    white-space: nowrap;
    position: relative;
    overflow: hidden;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--white);
    box-shadow: var(--shadow-sky);
  }

  .btn-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 30%,
      rgba(245, 158, 11, 0.35) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    pointer-events: none;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-primary:hover::before {
    transform: translateX(100%);
  }

  .btn-primary:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(14,165,233,0.35);
  }

  .btn-outline {
    background: transparent;
    color: var(--primary);
    border-color: var(--primary);
  }

  .btn-outline:hover {
    background: var(--primary);
    color: var(--white);
    transform: translateY(-2px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--gray-700);
    border-color: var(--gray-200);
  }

  .btn-ghost:hover {
    background: var(--gray-50);
    border-color: var(--primary);
    color: var(--primary);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .badge-sky {
    background: var(--sky-100);
    color: var(--sky-700);
    border: 1px solid var(--sky-200);
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--sky-500) 0%, var(--sky-700) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1px solid var(--gray-100);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }

  .card:hover {
    border-color: var(--sky-200);
    box-shadow: var(--shadow-sky);
    transform: translateY(-4px);
  }

  /* Section header */
  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 4rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .section-header p {
    color: var(--gray-500);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* Divider dot */
  .section-header .badge {
    margin-bottom: 1rem;
  }

  /* Fade-in animation */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }

  @keyframes pulse-ring {
    0% { transform: scale(0.9); opacity: 0.7; }
    50% { transform: scale(1.05); opacity: 0.3; }
    100% { transform: scale(0.9); opacity: 0.7; }
  }

  .animate-fade-up {
    animation: fadeUp 0.7s ease both;
  }

  .animate-float {
    animation: float 4s ease-in-out infinite;
  }

  /* Scroll-triggered reveal */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: opacity, transform;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
